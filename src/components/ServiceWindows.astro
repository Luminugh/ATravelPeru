---
const serviceWindows = [
  {
    key: "tours",
    badge: "Tours AT",
    title: "Arma tu recorrido ideal",
    subtitle: "Explora rutas pensadas para viajeros que quieren descubrir el Peru con ritmo, guia y experiencia completa.",
    accent: "#16a34a",
    summary: [
      "Rutas organizadas por dias y nivel de aventura.",
      "Guia, transporte y asistencia en un mismo paquete.",
      "Ideal para reservas rapidas y grupos pequenos."
    ],
    highlights: [
      { label: "Salidas", value: "Diarias" },
      { label: "Duracion", value: "1 a 5 dias" },
      { label: "Soporte", value: "24/7" }
    ],
    steps: ["Elige el recorrido", "Confirma tu fecha", "Recibe la atencion personalizada"],
    cta: "Ver recorridos disponibles"
  },
  {
    key: "vuelos",
    badge: "Vuelos",
    title: "Reserva tu vuelo con claridad",
    subtitle: "Compara rutas, horarios y beneficios para salir al destino correcto con una sola solicitud.",
    accent: "#22c55e",
    summary: [
      "Opciones nacionales con precios y equipaje claros.",
      "Asistencia para cambios, horarios y conexiones.",
      "Pensado para una reserva rapida y sin friccion."
    ],
    highlights: [
      { label: "Rutas", value: "50+" },
      { label: "Flexibilidad", value: "Alta" },
      { label: "Cambio", value: "Asistido" }
    ],
    steps: ["Selecciona origen y destino", "Revisa la tarifa", "Solicita tu vuelo"],
    cta: "Explorar vuelos"
  },
  {
    key: "hoteles",
    badge: "Hoteles",
    title: "Encuentra tu estadia ideal",
    subtitle: "Alojamientos pensados para descanso, ubicacion y mejor experiencia durante tu viaje.",
    accent: "#15803d",
    summary: [
      "Hoteles seleccionados por comodidad y ubicacion.",
      "Opciones para escapadas, familia o negocios.",
      "Reserva con soporte antes y durante tu viaje."
    ],
    highlights: [
      { label: "Categorias", value: "3 a 5 estrellas" },
      { label: "Servicios", value: "Desayuno / Spa" },
      { label: "Atencion", value: "Personalizada" }
    ],
    steps: ["Elige ciudad", "Compara beneficios", "Confirma tu estadia"],
    cta: "Ver hoteles disponibles"
  },
  {
    key: "paquetes",
    badge: "Paquetes",
    title: "Todo organizado en un solo paso",
    subtitle: "Paquetes completos para viajar con hotel, transporte y experiencia ya resueltos.",
    accent: "#65a30d",
    summary: [
      "Una sola reserva para todo el viaje.",
      "Ideal para escapadas cortas o recorridos completos.",
      "Te ayudamos a elegir segun presupuesto y plan."
    ],
    highlights: [
      { label: "Duracion", value: "2 a 6 dias" },
      { label: "Incluye", value: "Todo listo" },
      { label: "Ahorro", value: "Mayor" }
    ],
    steps: ["Selecciona el paquete", "Revisa lo incluido", "Confirma tu reserva"],
    cta: "Explorar paquetes"
  },
  {
    key: "ofertas",
    badge: "Ofertas",
    title: "Aprovecha descuentos activos",
    subtitle: "Promociones especiales para quien quiere reservar rapido y pagar menos.",
    accent: "#84cc16",
    summary: [
      "Promociones limitadas con cupos reales.",
      "Descuentos en vuelos, hoteles, tours y paquetes.",
      "Ventana pensada para cerrar la venta con rapidez."
    ],
    highlights: [
      { label: "Descuento", value: "Hasta 50%" },
      { label: "Duracion", value: "Limitada" },
      { label: "Acceso", value: "Inmediato" }
    ],
    steps: ["Revisa la promo", "Valida condiciones", "Solicita la oferta"],
    cta: "Ver ofertas activas"
  }
];
---

<div id="service-windows-overlay" class="service-windows-overlay" aria-hidden="true" onclick="if (event.target === this) closeServiceWindow()">
  {serviceWindows.map((service) => (
    <section
      class={`service-window service-window--${service.key}`}
      data-service={service.key}
      hidden
      role="dialog"
      aria-modal="true"
      aria-labelledby={`service-title-${service.key}`}
      style={`--service-accent: ${service.accent};`}
    >
      <button class="service-window__close" type="button" onclick="closeServiceWindow()" aria-label="Cerrar ventana">
        <i class="fas fa-times"></i>
      </button>

      <div class="service-window__eyebrow">{service.badge}</div>
      <h2 id={`service-title-${service.key}`} class="service-window__title">{service.title}</h2>
      <p class="service-window__subtitle">{service.subtitle}</p>

      <div class="service-window__grid">
        <article class="service-window__panel service-window__panel--summary">
          <h3 class="service-window__panel-title">Que incluye</h3>
          <ul class="service-window__list">
            {service.summary.map((item) => <li>{item}</li>)}
          </ul>
        </article>

        <article class="service-window__panel service-window__panel--highlights">
          <h3 class="service-window__panel-title">Datos rapidos</h3>
          <div class="service-window__highlights">
            {service.highlights.map((highlight) => (
              <div class="service-window__highlight">
                <span class="service-window__highlight-label">{highlight.label}</span>
                <strong class="service-window__highlight-value">{highlight.value}</strong>
              </div>
            ))}
          </div>
        </article>
      </div>

      <article class="service-window__panel service-window__panel--steps">
        <h3 class="service-window__panel-title">Como funciona</h3>
        <ol class="service-window__steps">
          {service.steps.map((step) => <li>{step}</li>)}
        </ol>
      </article>

      <div class="service-window__footer">
        <span class="service-window__cta-text">{service.cta}</span>
        <button class="service-window__button" type="button" onclick="closeServiceWindow(); showNotification('Tu solicitud fue registrada', 'success')">
          Solicitar atencion
        </button>
      </div>
    </section>
  ))}
</div>