<div style="background: #f5f5f5; padding: 20px; margin: 20px; border-radius: 8px; font-family: monospace; font-size: 12px;">
  <div style="color: #333; margin-bottom: 10px;"><strong>Diagnostico de Configuracion</strong></div>
  
  <div style="background: white; padding: 10px; margin: 5px 0; border-radius: 4px; border-left: 4px solid #ddd;">
    <div>PUBLIC_SUPABASE_URL: <span id="status-url" style="color: #666;">Verificando...</span></div>
  </div>
  
  <div style="background: white; padding: 10px; margin: 5px 0; border-radius: 4px; border-left: 4px solid #ddd;">
    <div>PUBLIC_SUPABASE_ANON_KEY: <span id="status-key" style="color: #666;">Verificando...</span></div>
  </div>
  
  <div id="supabase-status" style="background: white; padding: 10px; margin: 5px 0; border-radius: 4px; border-left: 4px solid #ddd; display: none;">
    <div>Estado de conexion: <span id="connection-status" style="color: #666;">Verificando...</span></div>
  </div>
</div>

<script>
  // Check environment variables
  const hasUrl = !!import.meta.env.PUBLIC_SUPABASE_URL;
  const hasKey = !!import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
  
  const urlEl = document.getElementById('status-url');
  const keyEl = document.getElementById('status-key');
  const statusDiv = document.getElementById('supabase-status');
  const connEl = document.getElementById('connection-status');
  
  if (urlEl) {
    urlEl.textContent = hasUrl ? '[OK]' : '[FALTA]';
    urlEl.style.color = hasUrl ? '#22863a' : '#cb2431';
  }
  
  if (keyEl) {
    keyEl.textContent = hasKey ? '[OK]' : '[FALTA]';
    keyEl.style.color = hasKey ? '#22863a' : '#cb2431';
  }
  
  if (statusDiv && hasUrl && hasKey) {
    statusDiv.style.display = 'block';
    // Try a simple Supabase request
    const testConnection = async () => {
      try {
        const { createClient } = await import('@supabase/supabase-js');
        const client = createClient(
          import.meta.env.PUBLIC_SUPABASE_URL,
          import.meta.env.PUBLIC_SUPABASE_ANON_KEY
        );
        const { data, error } = await client.from('v_tours_catalogo').select('count', { count: 'exact' }).limit(1);
        if (error) {
          connEl.textContent = '[ERROR] ' + error.message;
          connEl.style.color = '#cb2431';
        } else {
          connEl.textContent = '[CONECTADO]';
          connEl.style.color = '#22863a';
        }
      } catch (e) {
        connEl.textContent = '[ERROR] ' + (e instanceof Error ? e.message : 'Error desconocido');
        connEl.style.color = '#cb2431';
      }
    };
    setTimeout(testConnection, 1000);
  }
</script>
