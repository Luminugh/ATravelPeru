---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const isActive = (path: string) => currentPath === path;
---

<div id="mobile-menu" class="mobile-menu">
  <nav class="mobile-nav">
    <a href="/" class={`mobile-nav-link ${isActive("/") ? "active" : ""}`} onclick="toggleMobileMenu()">Principal</a>
    <a href="/tours-at" class={`mobile-nav-link ${isActive("/tours-at") ? "active" : ""}`} onclick="toggleMobileMenu()">Tours AT</a>
    <a href="/vuelos" class={`mobile-nav-link ${isActive("/vuelos") ? "active" : ""}`} onclick="toggleMobileMenu()">Vuelos</a>
    <a href="/hoteles" class={`mobile-nav-link ${isActive("/hoteles") ? "active" : ""}`} onclick="toggleMobileMenu()">Hoteles</a>
    <a href="/paquetes" class={`mobile-nav-link ${isActive("/paquetes") ? "active" : ""}`} onclick="toggleMobileMenu()">Paquetes</a>
    <a href="/ofertas" class={`mobile-nav-link ${isActive("/ofertas") ? "active" : ""}`} onclick="toggleMobileMenu()">Ofertas</a>
    <div class="mobile-menu-divider"></div>
    <a href="/ayuda" class="mobile-nav-link" onclick="toggleMobileMenu()">Ayuda</a>
  </nav>
</div>
