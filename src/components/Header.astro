---
import { headerConfig, siteIdentity } from "../lib/site-config";

const { navigationLinks, reserveHref, reserveLabel } = headerConfig;
---

<header class="header-premium">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="header-content">
      <a href="/" class="logo-brand">
        <img src="/assets/images/icon.png" alt={siteIdentity.brand} class="logo-icon" />
        <h1 class="logo-text">{siteIdentity.brand}</h1>
      </a>

      <nav class="nav-menu">
        {navigationLinks.map(link => (
          <a href={link.href} class="nav-link">
            {link.label}
          </a>
        ))}
      </nav>

      <div class="header-actions">
        <a href={reserveHref} class="cart-btn">
          <i class="fab fa-whatsapp"></i>
          <span>{reserveLabel}</span>
        </a>
      </div>
    </div>
  </div>
</header>
