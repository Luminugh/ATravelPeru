---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const isActive = (path: string) => currentPath === path;
---

<header class="header-premium">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="header-content">
      <a href="/" class="logo-brand">
        <i class="fas fa-plane logo-icon"></i>
        <h1 class="logo-text">ATRAVEL</h1>
      </a>

      <nav class="nav-menu">
        <a href="/" class={`nav-link ${isActive("/") ? "active" : ""}`}>Principal</a>
        <a href="/tours-at#tours-content" class={`nav-link ${isActive("/tours-at") ? "active" : ""}`}>Tours</a>
      </nav>

      <div class="header-actions">
        <a href="/tours-at#tours-content" class="cart-btn">
          <i class="fas fa-whatsapp"></i>
          <span>Reservar tours</span>
        </a>
      </div>
    </div>
  </div>
</header>
