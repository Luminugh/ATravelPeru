---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const isActive = (path: string) => currentPath === path;
---

<header class="header-premium">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="header-content">
      <a href="/" class="logo-brand">
        <i class="fas fa-plane logo-icon"></i>
        <h1 class="logo-text">ATRAVEL</h1>
      </a>

      <button class="hamburger-menu" onclick="toggleMobileMenu()">
        <i class="fas fa-bars"></i>
      </button>

      <nav class="nav-menu">
        <a href="/" class={`nav-link ${isActive("/") ? "active" : ""}`}>Principal</a>
        <a href="/tours-at" class={`nav-link ${isActive("/tours-at") ? "active" : ""}`}>Tours AT</a>
        <span class="nav-link nav-link-disabled" aria-disabled="true" title="Disponible pronto">Vuelos</span>
        <span class="nav-link nav-link-disabled" aria-disabled="true" title="Disponible pronto">Hoteles</span>
        <span class="nav-link nav-link-disabled" aria-disabled="true" title="Disponible pronto">Paquetes</span>
        <span class="nav-link nav-link-disabled" aria-disabled="true" title="Disponible pronto">Ofertas</span>
      </nav>

      <div class="header-actions">
        <a href="/ayuda" class="help-link">Ayuda</a>
        <button class="cart-btn" onclick="showNotification('Carrito en desarrollo')">
          <i class="fas fa-shopping-cart"></i>
          <span>Carrito</span>
        </button>
      </div>
    </div>
  </div>
</header>
