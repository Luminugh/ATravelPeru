---
import { footerConfig, siteIdentity } from "../lib/site-config";
---

<footer class="footer-premium" style="background-image: linear-gradient(135deg, rgba(0, 0, 0, 0.70) 0%, rgba(15, 0, 30, 0.70) 100%), url('/assets/images/ImageFooter.jpg'); background-position: center; background-size: cover; background-repeat: no-repeat;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="footer-minimal">
      <div class="footer-brand">
        <img src="/assets/images/icon.png" alt={siteIdentity.brand} class="footer-icon" />
        <h3>{siteIdentity.brand}</h3>
      </div>
      <p class="footer-desc">{footerConfig.description}</p>
    </div>
    <div class="footer-bottom">
      <p>© {new Date().getFullYear()} {siteIdentity.brand}. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>
