---
import "../styles/pages/admin/index.scss";

interface Props {
  title?: string;
}

const { title = "Panel Administrativo - ATRAVEL" } = Astro.props;
const currentPath = Astro.url.pathname;

const navClass = (...paths: string[]) => (paths.includes(currentPath) ? "nav-item active" : "nav-item");
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.0/css/all.min.css" />
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="admin-body">
    <div class="admin-container">
      <!-- Sidebar -->
      <aside class="admin-sidebar">
        <div class="sidebar-header">
          <h1 class="sidebar-logo">
            <i class="fas fa-compass"></i> ATRAVEL Admin
          </h1>
        </div>

        <nav class="sidebar-nav">
          <div class="nav-section">
            <span class="nav-section-title">Panel</span>
            <a href="/admin" class={navClass("/admin", "/admin/")}>
              <i class="fas fa-chart-line"></i>
              <span>Dashboard</span>
            </a>
          </div>

          <div class="nav-section">
            <span class="nav-section-title">Gestión de Contenido</span>
            <a href="/admin/tours" class={navClass("/admin/tours")}>
              <i class="fas fa-map"></i>
              <span>Tours AT</span>
            </a>
            <span class="nav-item nav-item-disabled" aria-disabled="true" title="Módulo deshabilitado">
              <i class="fas fa-plane"></i>
              <span>Vuelos (deshabilitado)</span>
            </span>
            <span class="nav-item nav-item-disabled" aria-disabled="true" title="Módulo deshabilitado">
              <i class="fas fa-hotel"></i>
              <span>Hoteles (deshabilitado)</span>
            </span>
            <span class="nav-item nav-item-disabled" aria-disabled="true" title="Módulo deshabilitado">
              <i class="fas fa-box"></i>
              <span>Paquetes (deshabilitado)</span>
            </span>
            <span class="nav-item nav-item-disabled" aria-disabled="true" title="Módulo deshabilitado">
              <i class="fas fa-tag"></i>
              <span>Ofertas (deshabilitado)</span>
            </span>
          </div>

          <div class="nav-section">
            <span class="nav-section-title">Canales y Ventas</span>
            <a href="/admin/catalogo" class={navClass("/admin/catalogo")}>
              <i class="fab fa-whatsapp"></i>
              <span>Catalogo y WhatsApp</span>
            </a>
          </div>

          <div class="nav-section">
            <a href="/" class="nav-item logout">
              <i class="fas fa-sign-out-alt"></i>
              <span>Volver al Sitio</span>
            </a>
          </div>
        </nav>
      </aside>

      <!-- Main Content -->
      <main class="admin-main">
        <!-- Top Bar -->
        <div class="admin-topbar">
          <div class="topbar-left">
            <button class="sidebar-toggle" id="sidebarToggle">
              <i class="fas fa-bars"></i>
            </button>
            <h2 class="page-title" id="pageTitle">Dashboard</h2>
          </div>
          <div class="topbar-right">
            <button class="admin-profile" id="adminSessionButton" type="button" title="Cerrar sesión">
              <img src="https://ui-avatars.com/api/?name=Admin+User&background=0D8ABC&color=fff" alt="Admin" class="profile-avatar" id="adminAvatar" />
              <div class="profile-info">
                <p class="profile-name" id="adminProfileName">Admin User</p>
                <p class="profile-meta" id="adminProfileMeta">Panel principal · Cerrar sesión</p>
              </div>
            </button>
          </div>
        </div>

        <!-- Content Area -->
        <div class="admin-content">
          <slot />
        </div>
      </main>
    </div>

    <script>
      // @ts-nocheck
      // Sidebar toggle functionality
      const sidebarToggle = document.getElementById('sidebarToggle');
      const adminSidebar = document.querySelector('.admin-sidebar');
      const adminContainer = document.querySelector('.admin-container');

      if (sidebarToggle && adminContainer) {
        sidebarToggle.addEventListener('click', () => {
          adminContainer.classList.toggle('sidebar-collapsed');
        });
      }

      // Navigation items click handlers
      const navItems = document.querySelectorAll('a.nav-item');
      navItems.forEach(item => {
        item.addEventListener('click', (e) => {
          // Remove active class from all items
          navItems.forEach(i => i.classList.remove('active'));
          // Add active class to clicked item
          item.classList.add('active');
          
          // Update page title
          const title = item.textContent.trim();
          const pageTitle = document.getElementById('pageTitle');
          if (pageTitle) {
            pageTitle.textContent = title;
          }
        });
      });

      async function logoutAndRedirect() {
        try {
          await fetch('/api/admin/auth/logout', {
            method: 'POST',
          });
        } finally {
          window.location.href = '/admin/login';
        }
      }

      // Session info for top-right profile button
      const adminProfileName = document.getElementById('adminProfileName');
      const adminAvatar = document.getElementById('adminAvatar');
      fetch('/api/admin/auth/me')
        .then((res) => res.json())
        .then((payload) => {
          if (!payload?.ok || !payload?.user) {
            window.location.href = '/admin/login';
            return;
          }

          const displayName = payload.user.nombre || payload.user.email || 'Admin User';
          if (adminProfileName) {
            adminProfileName.textContent = displayName;
          }
          if (adminAvatar instanceof HTMLImageElement) {
            adminAvatar.src = `https://ui-avatars.com/api/?name=${encodeURIComponent(displayName)}&background=0D8ABC&color=fff`;
          }
        })
        .catch(() => {
          window.location.href = '/admin/login';
        });

      const adminSessionButton = document.getElementById('adminSessionButton');
      if (adminSessionButton) {
        adminSessionButton.addEventListener('click', logoutAndRedirect);
      }

      // Inactivity control: if user stops interacting, session closes automatically.
      const ADMIN_IDLE_TIMEOUT_MS = 15 * 60 * 1000;
      const ADMIN_PING_THROTTLE_MS = 60 * 1000;
      let idleTimer = null;
      let lastPingAt = 0;

      function scheduleIdleLogout() {
        if (idleTimer) {
          clearTimeout(idleTimer);
        }
        idleTimer = setTimeout(() => {
          logoutAndRedirect();
        }, ADMIN_IDLE_TIMEOUT_MS);
      }

      function pingSession() {
        const now = Date.now();
        if (now - lastPingAt < ADMIN_PING_THROTTLE_MS) {
          return;
        }
        lastPingAt = now;
        fetch('/api/admin/auth/ping', { method: 'POST' }).catch(() => {
          window.location.href = '/admin/login';
        });
      }

      function onUserActivity() {
        scheduleIdleLogout();
        pingSession();
      }

      ['click', 'mousemove', 'keydown', 'scroll', 'touchstart'].forEach((eventName) => {
        window.addEventListener(eventName, onUserActivity, { passive: true });
      });

      scheduleIdleLogout();
      pingSession();
    </script>
  </body>
</html>
