---
import "../styles/pages/admin/index.scss";
import { adminSessionConfig, siteIdentity } from "../lib/site-config";

interface Props {
  title?: string;
}

const { title = siteIdentity.adminTitleDefault } = Astro.props;
const currentPath = Astro.url.pathname;

const navClass = (...paths: string[]) => (paths.includes(currentPath) ? "nav-item active" : "nav-item");

// Función para obtener el título de la página basado en la ruta
function getPageTitle(path: string): string {
  if (path === "/admin" || path === "/admin/") return "Dashboard";
  if (path === "/admin/tours") return "Tours AT";
  if (path === "/admin/media") return "Multimedia";
  if (path === "/admin/whatsapp-config") return "WhatsApp";
  if (path === "/admin/account") return "Mi Cuenta";
  return "Dashboard"; // fallback
}

const currentPageTitle = getPageTitle(currentPath);
const defaultProfileName = adminSessionConfig.defaultDisplayName;
const defaultAvatarSrc = `https://ui-avatars.com/api/?name=${encodeURIComponent(defaultProfileName)}&background=${adminSessionConfig.avatarBackground}&color=${adminSessionConfig.avatarColor}`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.0/css/all.min.css" />
  </head>
  <body class="admin-body">
    <!-- Loading screen para verificación de autenticación -->
    <div id="authLoadingScreen" class="auth-loading-screen">
      <div class="auth-loading-content">
        <div class="auth-loading-spinner"></div>
        <p class="auth-loading-text">Verificando autenticación...</p>
      </div>
    </div>

    <div class="admin-container" id="adminContainer" style="display: none;">
      <div class="admin-backdrop" id="adminBackdrop"></div>
      <!-- Sidebar -->
      <aside class="admin-sidebar">
        <div class="sidebar-header">
          <h1 class="sidebar-logo">
            <img src="/assets/images/icon.png" alt={siteIdentity.adminBrand} class="sidebar-logo-icon" /> {siteIdentity.adminBrand}
          </h1>
        </div>

        <nav class="sidebar-nav">
          <div class="nav-section">
            <span class="nav-section-title">Panel</span>
            <a href="/admin" class={navClass("/admin", "/admin/")}>
              <i class="fas fa-chart-line"></i>
              <span>Dashboard</span>
            </a>
          </div>

          <div class="nav-section">
            <span class="nav-section-title">Gestión de Contenido</span>
            <a href="/admin/tours" class={navClass("/admin/tours")}>
              <i class="fas fa-map"></i>
              <span>Tours AT</span>
            </a>
            <a href="/admin/media" class={navClass("/admin/media")}>
              <i class="fas fa-photo-video"></i>
              <span>Multimedia</span>
            </a>
            <a href="/admin/whatsapp-config" class={navClass("/admin/whatsapp-config")}>
              <i class="fab fa-whatsapp"></i>
              <span>WhatsApp</span>
            </a>
            <a href="/admin/account" class={navClass("/admin/account")}>
              <i class="fas fa-user-shield"></i>
              <span>Mi Cuenta</span>
            </a>
          </div>

          <div class="nav-section">
            <a href="#logout" class="nav-item logout" id="sidebarLogoutBtn">
              <i class="fas fa-right-from-bracket"></i>
              <span>Cerrar sesión</span>
            </a>
            <a href="/" class="nav-item logout">
              <i class="fas fa-sign-out-alt"></i>
              <span>Volver al Sitio</span>
            </a>
          </div>
        </nav>
      </aside>

      <!-- Main Content -->
      <main class="admin-main">
        <!-- Top Bar -->
        <div class="admin-topbar">
          <div class="topbar-left">
            <button class="sidebar-toggle" id="sidebarToggle">
              <i class="fas fa-bars"></i>
            </button>
            <h2 class="page-title" id="pageTitle">{currentPageTitle}</h2>
          </div>
          <div class="topbar-right">
            <button class="admin-profile" id="adminAccountButton" type="button" title="Ver cuenta">
              <img src={defaultAvatarSrc} alt="Admin" class="profile-avatar" id="adminAvatar" />
              <div class="profile-info">
                <p class="profile-name" id="adminProfileName">{defaultProfileName}</p>
                <p class="profile-meta" id="adminProfileMeta">Cuenta del vendedor</p>
              </div>
            </button>
          </div>
        </div>

        <!-- Content Area -->
        <div class="admin-content">
          <slot />
        </div>
      </main>
    </div>

    <script define:vars={{ adminSessionConfig, defaultProfileName }}>
      // @ts-nocheck
      
      // Variables globales
      const adminContainer = document.getElementById('adminContainer');
      const authLoadingScreen = document.getElementById('authLoadingScreen');
      const adminBackdrop = document.getElementById('adminBackdrop');
      const adminAccountButton = document.getElementById('adminAccountButton');

      async function logoutAndRedirect() {
        try {
          await fetch('/api/admin/auth/logout', {
            method: 'POST',
          });
        } finally {
          window.location.href = '/admin/login';
        }
      }

      // VERIFICACIÓN DE AUTENTICACIÓN - DEBE EJECUTARSE PRIMERO
      async function verifyAuthentication() {
        try {
          const response = await fetch('/api/admin/auth/me');
          const payload = await response.json();

          if (!payload?.ok || !payload?.user) {
            // No autenticado - redirigir a login
            window.location.href = '/admin/login';
            return false;
          }

          // Autenticado - mostrar contenido
          if (authLoadingScreen) {
            authLoadingScreen.style.display = 'none';
          }
          if (adminContainer) {
            adminContainer.style.display = 'block';
          }

          return true;
        } catch (error) {
          console.error('Error verificando autenticación:', error);
          window.location.href = '/admin/login';
          return false;
        }
      }

      // Ejecutar verificación inmediatamente
      verifyAuthentication().then((isAuthenticated) => {
        if (!isAuthenticated) return;

        // Solo ejecutar el resto del código si está autenticado
        
        // Sidebar toggle functionality
        const sidebarToggle = document.getElementById('sidebarToggle');
        const isMobile = () => window.matchMedia('(max-width: 768px)').matches;

        function closeSidebar() {
          if (!adminContainer) return;
          adminContainer.classList.remove('sidebar-active');
          adminContainer.classList.remove('sidebar-collapsed');
          document.body.classList.remove('admin-drawer-open');
        }

        function openSidebar() {
          if (!adminContainer) return;
          adminContainer.classList.add('sidebar-active');
          document.body.classList.add('admin-drawer-open');
        }

        function toggleSidebar() {
          if (!adminContainer) return;
          if (isMobile()) {
            if (adminContainer.classList.contains('sidebar-active')) {
              closeSidebar();
            } else {
              openSidebar();
            }
            return;
          }

          adminContainer.classList.toggle('sidebar-collapsed');
        }

        const SIDEBAR_STATE_KEY = 'adminSidebarCollapsed';

        function restoreSidebarState() {
          if (!adminContainer) return;

          const savedState = localStorage.getItem(SIDEBAR_STATE_KEY);
          if (savedState === 'true' && !isMobile()) {
            adminContainer.classList.add('sidebar-collapsed');
            document.body.classList.remove('admin-drawer-open');
          }
        }

        function saveSidebarState() {
          if (!adminContainer) return;
          localStorage.setItem(SIDEBAR_STATE_KEY, adminContainer.classList.contains('sidebar-collapsed').toString());
        }

        if (sidebarToggle && adminContainer) {
          sidebarToggle.addEventListener('click', () => {
            toggleSidebar();
            saveSidebarState();
          });
        }

        if (adminBackdrop) {
          adminBackdrop.addEventListener('click', closeSidebar);
        }

        restoreSidebarState();

        // Navigation items click handlers
        const navItems = document.querySelectorAll('a.nav-item');
        navItems.forEach(item => {
          item.addEventListener('click', (e) => {
            // Remove active class from all items
            navItems.forEach(i => i.classList.remove('active'));
            // Add active class to clicked item
            item.classList.add('active');

            if (isMobile()) {
              closeSidebar();
            }

            saveSidebarState();
            
            // Update page title
            const title = item.textContent.trim();
            const pageTitle = document.getElementById('pageTitle');
            if (pageTitle) {
              pageTitle.textContent = title;
            }
          });
        });

        // Session info for top-right profile button
        const adminProfileName = document.getElementById('adminProfileName');
        const adminAvatar = document.getElementById('adminAvatar');
        
        fetch('/api/admin/auth/me')
          .then((res) => res.json())
          .then((payload) => {
            if (!payload?.ok || !payload?.user) {
              window.location.href = '/admin/login';
              return;
            }

            const displayName = payload.vendedor?.nombre?.trim() || payload.user.nombre || payload.user.email || defaultProfileName;
            if (adminProfileName) {
              adminProfileName.textContent = displayName;
            }
            if (adminAvatar instanceof HTMLImageElement) {
              adminAvatar.src = `https://ui-avatars.com/api/?name=${encodeURIComponent(displayName)}&background=${adminSessionConfig.avatarBackground}&color=${adminSessionConfig.avatarColor}`;
            }
          })
          .catch(() => {
            window.location.href = '/admin/login';
          });

        if (adminAccountButton) {
          adminAccountButton.addEventListener('click', () => {
            window.location.href = '/admin/account';
          });
        }

        const sidebarLogoutBtn = document.getElementById('sidebarLogoutBtn');
        if (sidebarLogoutBtn) {
          sidebarLogoutBtn.addEventListener('click', (event) => {
            event.preventDefault();
            logoutAndRedirect();
          });
        }

        window.addEventListener('resize', () => {
          if (!isMobile()) {
            document.body.classList.remove('admin-drawer-open');
            adminContainer?.classList.remove('sidebar-active');
          }
        });

        // Inactivity control: if user stops interacting, session closes automatically.
        const ADMIN_IDLE_TIMEOUT_MS = adminSessionConfig.idleTimeoutMs;
        const ADMIN_PING_THROTTLE_MS = adminSessionConfig.pingThrottleMs;
        let idleTimer = null;
        let lastPingAt = 0;

        function scheduleIdleLogout() {
          if (idleTimer) {
            clearTimeout(idleTimer);
          }
          idleTimer = setTimeout(() => {
            logoutAndRedirect();
          }, ADMIN_IDLE_TIMEOUT_MS);
        }

        function pingSession() {
          const now = Date.now();
          if (now - lastPingAt < ADMIN_PING_THROTTLE_MS) {
            return;
          }
          lastPingAt = now;
          fetch('/api/admin/auth/ping', { method: 'POST' }).catch(() => {
            window.location.href = '/admin/login';
          });
        }

        function onUserActivity() {
          scheduleIdleLogout();
          pingSession();
        }

        ['click', 'mousemove', 'keydown', 'scroll', 'touchstart'].forEach((eventName) => {
          window.addEventListener(eventName, onUserActivity, { passive: true });
        });

        scheduleIdleLogout();
        pingSession();
      });
    </script>

    <style>
      .auth-loading-screen {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, #16a34a 0%, #22c55e 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
      }

      .auth-loading-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 20px;
      }
      .sidebar-logo-icon {
        width: 20px;
        height: 20px;
        object-fit: contain;
        display: inline-block;
        vertical-align: middle;
      }

      .sidebar-logo {
        font-size: 18px;
      }

      .auth-loading-spinner {
        width: 50px;
        height: 50px;
        border: 4px solid rgba(255, 255, 255, 0.3);
        border-top-color: white;
        border-radius: 50%;
        animation: spin 1s linear infinite;
      }

      .auth-loading-text {
        color: white;
        font-size: 18px;
        font-weight: 600;
        margin: 0;
      }

      .admin-backdrop {
        display: none;
      }

      .admin-drawer-open {
        overflow: hidden;
      }

      @keyframes spin {
        to {
          transform: rotate(360deg);
        }
      }
    </style>
  </body>
</html>
