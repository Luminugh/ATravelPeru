---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/app.scss";
import { siteIdentity, siteMetadata } from "../lib/site-config";

interface Props {
  title?: string;
}

const { title = siteIdentity.appTitleDefault } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={siteMetadata.description} />
    <meta name="theme-color" content="#16a34a" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={siteMetadata.description} />
    <meta property="og:url" content={siteMetadata.siteUrl} />
    <meta property="og:image" content={siteMetadata.image} />
    <meta property="og:site_name" content={siteIdentity.brand} />

    <meta name="twitter:card" content={siteMetadata.twitterCard} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={siteMetadata.description} />
    <meta name="twitter:image" content={siteMetadata.image} />
    <meta name="twitter:site" content={siteMetadata.twitterSite} />

    <link rel="canonical" href={siteMetadata.siteUrl} />
    <link rel="icon" type="image/png" href={siteMetadata.iconPath} />
    <link rel="apple-touch-icon" href={siteMetadata.iconPath} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.0/css/all.min.css" />
  </head>
  <body>
    <Header currentPath={currentPath} />

    <slot />

    <Footer />
  </body>
</html>
