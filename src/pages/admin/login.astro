---
export const prerender = false;

const title = "Login Admin - ATRAVEL";
const next = Astro.url.searchParams.get("next") || "/admin";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.0/css/all.min.css" />
    <style>
      :root {
        color-scheme: light;
      }
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: "Outfit", sans-serif;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
      }
      .login-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        max-width: 1000px;
        width: 100%;
        gap: 0;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
      }
      .login-visual {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 60px 40px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        color: white;
        text-align: center;
      }
      .login-visual-icon {
        font-size: 80px;
        margin-bottom: 30px;
        opacity: 0.95;
      }
      .login-visual h2 {
        font-size: 32px;
        font-weight: 700;
        margin-bottom: 15px;
      }
      .login-visual p {
        font-size: 16px;
        opacity: 0.9;
        line-height: 1.6;
      }
      .login-form-container {
        background: #ffffff;
        padding: 50px 40px;
        display: flex;
        flex-direction: column;
        justify-content: center;
      }
      .login-brand {
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 800;
        color: #667eea;
        margin-bottom: 30px;
        font-size: 18px;
      }
      .login-brand i {
        font-size: 24px;
      }
      h1 {
        margin: 0 0 10px;
        font-size: 28px;
        font-weight: 700;
        color: #1a202c;
      }
      .subtitle {
        margin: 0 0 30px;
        font-size: 14px;
        color: #718096;
        line-height: 1.6;
      }
      .field {
        display: grid;
        gap: 8px;
        margin-bottom: 20px;
      }
      label {
        font-size: 13px;
        font-weight: 600;
        color: #2d3748;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }
      input {
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: 12px 14px;
        font-size: 15px;
        font-family: inherit;
        transition: all 0.3s ease;
      }
      input:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
      }
      .btn {
        width: 100%;
        border: 0;
        border-radius: 8px;
        padding: 12px 14px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: #fff;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
        margin-top: 10px;
        transition: all 0.3s ease;
      }
      .btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);
      }
      .btn:disabled {
        opacity: 0.6;
        cursor: wait;
      }
      .error {
        margin-top: 15px;
        padding: 12px 14px;
        border-radius: 8px;
        background: #fee2e2;
        color: #991b1b;
        border: 1px solid #fecaca;
        display: none;
        font-size: 14px;
      }
      .error.show {
        display: block;
      }
      @media (max-width: 768px) {
        .login-container {
          grid-template-columns: 1fr;
        }
        .login-visual {
          padding: 40px 30px;
        }
        .login-form-container {
          padding: 40px 30px;
        }
      }
    </style>
  </head>
  <body>
    <div class="login-container">
      <div class="login-visual">
        <div class="login-visual-icon">
          <i class="fas fa-map"></i>
        </div>
        <h2>Bienvenido</h2>
        <p>Accede a tu panel de administración para gestionar tours, destinos y más.</p>
      </div>
      
      <div class="login-form-container">
        <div class="login-brand">
          <i class="fas fa-compass"></i> ATRAVEL Admin
        </div>
        <h1>Iniciar sesión</h1>
        <p class="subtitle">Ingresa tus credenciales para continuar.</p>

        <form id="adminLoginForm">
          <div class="field">
            <label for="email">Correo Electrónico</label>
            <input id="email" name="email" type="email" required autocomplete="email" placeholder="tu@email.com" />
          </div>
          <div class="field">
            <label for="password">Contraseña</label>
            <input id="password" name="password" type="password" required autocomplete="current-password" placeholder="••••••••" />
          </div>

          <button class="btn" type="submit" id="loginBtn">
            <i class="fas fa-sign-in-alt"></i> Entrar al panel
          </button>
          <div id="errorBox" class="error"></div>
        </form>
      </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.0/js/all.min.js"></script>
    <script define:vars={{ next }}>
      const form = document.getElementById("adminLoginForm");
      const loginBtn = document.getElementById("loginBtn");
      const errorBox = document.getElementById("errorBox");

      function setError(message) {
        errorBox.textContent = message;
        errorBox.classList.add("show");
      }

      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        errorBox.classList.remove("show");
        loginBtn.disabled = true;

        const formData = new FormData(form);
        const email = String(formData.get("email") || "").trim();
        const password = String(formData.get("password") || "");

        try {
          const response = await fetch("/api/admin/auth/login", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({ email, password }),
          });

          const payload = await response.json();
          if (!response.ok || !payload.ok) {
            setError(payload.error || "No fue posible iniciar sesion.");
            loginBtn.disabled = false;
            return;
          }

          window.location.href = next;
        } catch {
          setError("No fue posible conectar con el servidor.");
          loginBtn.disabled = false;
        }
      });
    </script>
  </body>
</html>
