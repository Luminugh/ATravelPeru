---
import AdminLayout from "../../layouts/AdminLayout.astro";

const title = "Gestión de Vuelos - Panel Admin";
---

<AdminLayout title={title}>
  <!-- Vuelos Section -->
  <section class="content-section">
    <div class="section-header">
      <h3>
        <i class="fas fa-plane"></i>
        Gestión de Vuelos
      </h3>
      <div class="section-actions">
        <button class="btn btn-primary">
          <i class="fas fa-plus"></i>
          Nuevo Vuelo
        </button>
        <button class="btn btn-secondary">
          <i class="fas fa-download"></i>
          Exportar
        </button>
      </div>
    </div>

    <div class="search-bar">
      <div class="search-input">
        <i class="fas fa-search search-icon"></i>
        <input type="text" placeholder="Buscar vuelos por ruta..." />
      </div>
      <div class="filter-select">
        <select>
          <option>Todas las aerolíneas</option>
          <option>LATAM</option>
          <option>Avianca</option>
          <option>Sky Airline</option>
        </select>
      </div>
    </div>

    <table class="data-table">
      <thead>
        <tr>
          <th>Vuelo</th>
          <th>Ruta</th>
          <th>Aerolínea</th>
          <th>Precio</th>
          <th>Disponibilidad</th>
          <th>Estado</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><span class="item-name">LA 501</span></td>
          <td>Lima - Cusco</td>
          <td>LATAM</td>
          <td>$120</td>
          <td>145 asientos</td>
          <td><span class="item-status active">Activo</span></td>
          <td>
            <div class="item-actions">
              <button class="action-btn edit" title="Editar">
                <i class="fas fa-edit"></i>
              </button>
              <button class="action-btn view" title="Ver">
                <i class="fas fa-eye"></i>
              </button>
              <button class="action-btn delete" title="Eliminar">
                <i class="fas fa-trash"></i>
              </button>
            </div>
          </td>
        </tr>
        <tr>
          <td><span class="item-name">AV 220</span></td>
          <td>Lima - Iquitos</td>
          <td>Avianca</td>
          <td>$180</td>
          <td>98 asientos</td>
          <td><span class="item-status active">Activo</span></td>
          <td>
            <div class="item-actions">
              <button class="action-btn edit" title="Editar">
                <i class="fas fa-edit"></i>
              </button>
              <button class="action-btn view" title="Ver">
                <i class="fas fa-eye"></i>
              </button>
              <button class="action-btn delete" title="Eliminar">
                <i class="fas fa-trash"></i>
              </button>
            </div>
          </td>
        </tr>
      </tbody>
    </table>
  </section>
</AdminLayout>
