---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { siteIdentity } from "../../lib/site-config";

export const prerender = true;

const title = siteIdentity.adminTitleDefault;
---

<AdminLayout title={title}>
  <!-- Dashboard Section -->
  <section id="dashboard-section" class="dashboard-section">
    <!-- Stats Cards -->
    <div class="dashboard-grid">
      <div class="stat-card stat-card-tours">
        <div class="stat-icon">
          <i class="fas fa-map"></i>
        </div>
        <p class="stat-label">Tours disponibles</p>
        <p class="stat-value">Gestión activa</p>
        <p class="stat-change">Administra tours y revisa su publicación en el catálogo</p>
      </div>
    </div>

    <!-- Quick Navigation Info Card -->
    <div class="info-card" style="margin-top: 40px;">
      <div class="info-card-header">
        <h3 style="margin: 0; display: flex; align-items: center; gap: 10px; color: white; font-size: 20px;">
          <i class="fas fa-lightbulb"></i>
          Navegación Rápida
        </h3>
      </div>
      <div class="info-card-content">
        <p style="color: #555; margin-bottom: 15px; line-height: 1.6;">
          Utiliza el menú lateral para administrar tours, destinos y el acceso al catálogo público.
        </p>
        <ul style="color: #666; margin: 0 0 20px 0; padding-left: 20px; line-height: 1.8;">
          <li><strong style="color: #16a34a;">Gestión de Contenido:</strong> Tours AT y destinos</li>
          <li><strong style="color: #16a34a;">Reservas:</strong> Flujo de WhatsApp asociado al catálogo público de tours</li>
        </ul>
        <a href="/admin/tours" class="btn-primary-inline" style="display: inline-flex; align-items: center; gap: 8px; padding: 0.75rem 1.5rem; text-decoration: none; border-radius: 8px; background: linear-gradient(135deg, #22c55e 0%, #15803d 100%); color: white; font-weight: 600; transition: all 0.3s ease;">
          <i class="fas fa-arrow-right"></i> Ir al Gestor de Tours AT
        </a>
      </div>
    </div>
  </section>

  <style>
    .dashboard-section {
      padding: 30px;
    }

    .dashboard-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 24px;
      margin-bottom: 40px;
    }

    .stat-card {
      background: white;
      border-radius: 12px;
      padding: 24px;
      border: 1px solid #e0e0e0;
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
    }

    .stat-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: linear-gradient(90deg, #22c55e, #15803d);
    }

    .stat-card:hover {
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
      transform: translateY(-4px);
    }

    .stat-card-tours::before {
      background: linear-gradient(90deg, #22c55e, #15803d);
    }

    .stat-icon {
      width: 50px;
      height: 50px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 24px;
      margin-bottom: 16px;
      color: white;
    }

    .stat-card-tours .stat-icon {
      background: linear-gradient(135deg, #22c55e, #15803d);
    }

    .stat-label {
      margin: 0 0 8px;
      font-size: 13px;
      font-weight: 600;
      color: #718096;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .stat-value {
      margin: 0 0 8px;
      font-size: 32px;
      font-weight: 700;
      color: #1a202c;
    }

    .stat-change {
      margin: 0;
      font-size: 13px;
      color: #a0aec0;
    }

    .info-card {
      background: white;
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid #e0e0e0;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.07);
    }

    .info-card-header {
      background: linear-gradient(135deg, #16a34a 0%, #22c55e 100%) !important;
      padding: 24px;
    }

    .info-card-header h3 {
      color: #ffffff;
    }

    .stat-card-tours::before {
      background: linear-gradient(90deg, #22c55e, #15803d) !important;
    }

    .stat-card-tours .stat-icon {
      background: linear-gradient(135deg, #22c55e, #15803d) !important;
    }

    .info-card-content {
      padding: 24px;
    }

    .btn-primary-inline:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 16px rgba(16, 185, 129, 0.3);
    }
  </style>
</AdminLayout>
