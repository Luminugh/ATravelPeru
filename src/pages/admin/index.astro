---
import AdminLayout from "../../layouts/AdminLayout.astro";

const title = "Panel Administrativo - ATRAVEL";
---

<AdminLayout title={title}>
  <!-- Dashboard Section -->
  <section id="dashboard-section" class="dashboard-section">
    <!-- Stats Cards -->
    <div class="dashboard-grid">
      <div class="stat-card">
        <div class="stat-icon tours">
          <i class="fas fa-map"></i>
        </div>
        <p class="stat-label">Tours Activos</p>
        <p class="stat-value">48</p>
        <p class="stat-change">? 12% desde el mes pasado</p>
      </div>

      <div class="stat-card">
        <div class="stat-icon flights">
          <i class="fas fa-plane"></i>
        </div>
        <p class="stat-label">Vuelos Disponibles</p>
        <p class="stat-value">256</p>
        <p class="stat-change">? 8% desde el mes pasado</p>
      </div>

      <div class="stat-card">
        <div class="stat-icon hotels">
          <i class="fas fa-hotel"></i>
        </div>
        <p class="stat-label">Hoteles Registrados</p>
        <p class="stat-value">132</p>
        <p class="stat-change">? 5% desde el mes pasado</p>
      </div>
    </div>

    <!-- Quick Navigation Info Card -->
    <div class="quick-nav-info" style="margin-top: 40px; padding: 20px; background: #f0f7ff; border-left: 4px solid #3b82f6; border-radius: 8px;">
      <h3 style="margin-top: 0; color: #1e40af;">
        <i class="fas fa-lightbulb"></i>
        Navegaci�n R�pida
      </h3>
      <p style="color: #555; margin-bottom: 15px;">
        Utiliza el men� lateral para acceder a las diferentes secciones de gesti�n:
      </p>
      <ul style="color: #666; margin: 0; padding-left: 20px;">
        <li><strong>Gesti�n de Contenido:</strong> Tours AT, Vuelos, Hoteles, Paquetes, Ofertas</li>
      </ul>
    </div>
  </section>
</AdminLayout>
