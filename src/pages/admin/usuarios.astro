---
import AdminLayout from "../../layouts/AdminLayout.astro";

const title = "Gestión de Usuarios - Panel Admin";
---

<AdminLayout title={title}>
  <!-- Usuarios Section -->
  <section class="content-section">
    <div class="section-header">
      <h3>
        <i class="fas fa-users"></i>
        Gestión de Usuarios
      </h3>
      <div class="section-actions">
        <button class="btn btn-primary">
          <i class="fas fa-plus"></i>
          Nuevo Usuario
        </button>
        <button class="btn btn-secondary">
          <i class="fas fa-download"></i>
          Exportar
        </button>
      </div>
    </div>

    <div class="search-bar">
      <div class="search-input">
        <i class="fas fa-search search-icon"></i>
        <input type="text" placeholder="Buscar usuarios por email..." />
      </div>
      <div class="filter-select">
        <select>
          <option>Todos los roles</option>
          <option>Administrador</option>
          <option>Cliente</option>
          <option>Vendedor</option>
        </select>
      </div>
    </div>

    <table class="data-table">
      <thead>
        <tr>
          <th>Usuario</th>
          <th>Email</th>
          <th>Teléfono</th>
          <th>Rol</th>
          <th>Fecha Registro</th>
          <th>Estado</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><span class="item-name">Juan Pérez</span></td>
          <td>juan@example.com</td>
          <td>+51 987 654 321</td>
          <td>Cliente</td>
          <td>15/01/2026</td>
          <td><span class="item-status active">Activo</span></td>
          <td>
            <div class="item-actions">
              <button class="action-btn edit" title="Editar">
                <i class="fas fa-edit"></i>
              </button>
              <button class="action-btn view" title="Ver">
                <i class="fas fa-eye"></i>
              </button>
              <button class="action-btn delete" title="Eliminar">
                <i class="fas fa-trash"></i>
              </button>
            </div>
          </td>
        </tr>
        <tr>
          <td><span class="item-name">María García</span></td>
          <td>maria@example.com</td>
          <td>+51 991 234 567</td>
          <td>Vendedor</td>
          <td>20/02/2026</td>
          <td><span class="item-status active">Activo</span></td>
          <td>
            <div class="item-actions">
              <button class="action-btn edit" title="Editar">
                <i class="fas fa-edit"></i>
              </button>
              <button class="action-btn view" title="Ver">
                <i class="fas fa-eye"></i>
              </button>
              <button class="action-btn delete" title="Eliminar">
                <i class="fas fa-trash"></i>
              </button>
            </div>
          </td>
        </tr>
        <tr>
          <td><span class="item-name">Carlos López</span></td>
          <td>carlos@example.com</td>
          <td>+51 995 789 012</td>
          <td>Cliente</td>
          <td>10/03/2026</td>
          <td><span class="item-status inactive">Inactivo</span></td>
          <td>
            <div class="item-actions">
              <button class="action-btn edit" title="Editar">
                <i class="fas fa-edit"></i>
              </button>
              <button class="action-btn view" title="Ver">
                <i class="fas fa-eye"></i>
              </button>
              <button class="action-btn delete" title="Eliminar">
                <i class="fas fa-trash"></i>
              </button>
            </div>
          </td>
        </tr>
      </tbody>
    </table>
  </section>
</AdminLayout>
