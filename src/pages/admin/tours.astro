---
import AdminLayout from "../../layouts/AdminLayout.astro";
import MediaPicker from "../../components/MediaPicker.astro";
import { siteIdentity } from "../../lib/site-config";

export const prerender = true;

const title = `Gestion de Tours AT - ${siteIdentity.adminTitleDefault}`;
---

<AdminLayout title={title}>
  <!-- Tours Section -->
  <section class="content-section">
    <div class="section-header section-header-spaced">
      <div>
        <h3><i class="fas fa-map"></i> Gestión de Tours AT</h3>
        <p id="tourCount" class="section-description">Cargando...</p>
      </div>
      <div class="section-actions">
        <button id="newBtn" class="btn btn-primary btn-lg"><i class="fas fa-plus"></i> Nuevo Tour</button>
      </div>
    </div>

    <!-- Controles de búsqueda y filtro mejorado -->
    <div class="tours-controls">
      <div class="search-row">
        <div class="search-input">
          <i class="fas fa-search"></i>
          <input id="searchInput" type="text" placeholder="Buscar por título o destino..." />
        </div>
        <select id="filterStatus" class="select-input">
          <option value="">Todos los estados</option>
          <option value="activo">Activo</option>
          <option value="inactivo">Inactivo</option>
        </select>
        <select id="filterDestino" class="select-input">
          <option value="">Todos los destinos</option>
        </select>
      </div>
    </div>

    <!-- Grid de tarjetas -->
    <div id="toursList" class="tours-grid"></div>

    <!-- Empty state -->
    <div id="emptyState" class="empty-state" style="display: none;">
      <i class="fas fa-inbox"></i>
      <p>No se encontraron tours</p>
      <p>Crea uno nuevo para empezar</p>
    </div>

    <!-- Modal overlay -->
    <div id="modalOverlay" class="modal-overlay" style="display: none;"></div>

    <!-- Edit modal mejorado -->
    <div id="editor" class="tour-editor" style="display: none;">
      <div class="editor-header">
        <h2 id="modalTitle">Nuevo Tour</h2>
        <button type="button" id="closeBtn" class="editor-close">&times;</button>
      </div>
      <form id="editorForm" class="editor-form">
        <input type="hidden" name="id" />
        
        <!-- SECCIÓN 1: Información Básica -->
        <div class="form-section">
          <h3 class="section-title"><i class="fas fa-info-circle"></i> Información Básica</h3>
          
          <div class="form-row">
            <label><i class="fas fa-heading"></i> Título del Tour *</label>
            <input name="titulo" required placeholder="Ej. Machu Picchu Express" />
          </div>

          <div class="form-row">
            <label><i class="fas fa-file-alt"></i> Descripción Corta *</label>
            <textarea name="descripcion" rows="2" required placeholder="Describe brevemente el tour..."></textarea>
          </div>

          <div class="form-row grid-3">
            <div>
              <label><i class="fas fa-dollar-sign"></i> Precio (USD) *</label>
              <input type="number" step="0.01" name="precio" required placeholder="1200" />
            </div>
            <div>
              <label><i class="fas fa-hourglass-end"></i> Duración *</label>
              <input name="duracion" required placeholder="Ej. 3 dias" />
            </div>
            <div>
              <label><i class="fas fa-location-dot"></i> Destino *</label>
              <select name="ubicacion_id" required></select>
            </div>
          </div>
        </div>

        <!-- SECCIÓN 2: Imagen Principal -->
        <div class="form-section">
          <h3 class="section-title"><i class="fas fa-image"></i> Imagen Principal</h3>
          <div class="form-row">
            <label>URL de la Imagen *</label>
            <div style="display:flex; gap:0.5rem; align-items:center;">
              <input id="imagenPrincipalInput" name="imagen_principal" placeholder="https://images.unsplash.com/..." onchange="updateImagePreview(this.value)" />
              <button type="button" id="selectPrimaryBtn" class="btn">Seleccionar</button>
            </div>
          </div>
          <div id="imagePreview" class="image-preview-box" style="display: none;">
            <img id="previewImg" alt="Vista previa" />
          </div>
        </div>

        <!-- SECCIÓN 3: Qué Incluye / No Incluye -->
        <div class="form-section">
          <h3 class="section-title"><i class="fas fa-list"></i> Contenido del Tour</h3>
          
          <div class="form-row grid-2">
            <div>
              <label class="label-success"><i class="fas fa-check-circle"></i> Incluye *</label>
              <textarea name="incluye" rows="3" placeholder="Transporte, entradas, guia, hotel..."></textarea>
            </div>
            <div>
              <label class="label-danger"><i class="fas fa-times-circle"></i> No Incluye</label>
              <textarea name="no_incluye" rows="3" placeholder="Seguro, gastos personales, propinas..."></textarea>
            </div>
          </div>
        </div>

        <!-- SECCIÓN 4: Itinerario Detallado -->
        <div class="form-section">
          <h3 class="section-title"><i class="fas fa-map"></i> Itinerario Detallado</h3>
          
          <div class="form-row">
            <label>Descripcion dia a dia</label>
            <textarea name="itinerario" rows="4" placeholder="Dia 1 actividad. Dia 2 actividad. Dia 3 actividad..."></textarea>
          </div>
        </div>

        <!-- SECCIÓN 5: Galería de Fotos -->
        <div class="form-section">
          <h3 class="section-title"><i class="fas fa-images"></i> Galería de Fotos (Opcional)</h3>
          
          <div class="form-row gallery-row">
            <label>Array JSON con imágenes</label>
            <small>{"Usa el selector para insertar imágenes o pega un array JSON. Ej. [{\"imagen\":\"https://...\",\"orden\":1}]"}</small>
            <div style="display:flex; gap:0.5rem; align-items:center; margin-bottom:0.5rem;">
              <button id="openGalleryPicker" type="button" class="btn btn-secondary">Abrir selector</button>
              <button id="insertGalleryFromUrls" type="button" class="btn">Insertar URLs (copiar/pegar)</button>
            </div>
            <textarea id="galeriaTextarea" name="galeria" rows="3" placeholder='[{"imagen":"https://...","orden":1}]'></textarea>
          </div>
        </div>

        <!-- SECCIÓN 6: Opciones Avanzadas -->
        <div class="form-section">
          <h3 class="section-title"><i class="fas fa-cog"></i> Opciones</h3>
          
          <div class="form-row options-row">
            <label class="checkbox-inline">
              <input type="checkbox" name="destacado" />
              <span><i class="fas fa-star label-warning"></i> Destacado (mostrar en portada)</span>
            </label>
          </div>

          <div class="form-row">
            <label>Estado de Publicación</label>
            <div class="radio-group">
              <label class="radio-inline">
                <input type="radio" name="estado" value="activo" checked />
                <span><i class="fas fa-eye"></i> Activo (visible)</span>
              </label>
              <label class="radio-inline">
                <input type="radio" name="estado" value="inactivo" />
                <span><i class="fas fa-eye-slash"></i> Inactivo (oculto)</span>
              </label>
            </div>
          </div>
        </div>

        <!-- Botones de acción -->
        <div class="form-actions">
          <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Guardar Tour</button>
          <button type="button" id="cancelBtn" class="btn btn-secondary"><i class="fas fa-times"></i> Cancelar</button>
        </div>
      </form>
    </div>
    <!-- Media Picker Modal -->
    <MediaPicker />
  </section>

    <script type="module">
      const api = {
        list: () => fetch('/api/admin/tours').then(r=>r.json()),
        create: (payload) => fetch('/api/admin/tours', { method: 'POST', headers:{'content-type':'application/json'}, body: JSON.stringify(payload)}).then(r=>r.json()),
        update: (payload) => fetch('/api/admin/tours', { method: 'PUT', headers:{'content-type':'application/json'}, body: JSON.stringify(payload)}).then(r=>r.json()),
        del: (id) => fetch('/api/admin/tours', { method: 'DELETE', headers:{'content-type':'application/json'}, body: JSON.stringify({id})}).then(r=>r.json()),
        ubicaciones: () => fetch('/api/admin/ubicaciones').then(r=>r.json()),
      };

      const listEl = document.getElementById('toursList');
      const emptyEl = document.getElementById('emptyState');
      const editor = document.getElementById('editor');
      const modalOverlay = document.getElementById('modalOverlay');
      const form = document.getElementById('editorForm');
      const newBtn = document.getElementById('newBtn');
      const cancelBtn = document.getElementById('cancelBtn');
      const closeBtn = document.getElementById('closeBtn');
      const searchInput = document.getElementById('searchInput');
      const filterStatus = document.getElementById('filterStatus');
      const filterDestino = document.getElementById('filterDestino');
      const tourCount = document.getElementById('tourCount');

      let tours = [];
      let ubicaciones = [];

      async function load() {
        const [tRes, uRes] = await Promise.all([api.list(), api.ubicaciones()]);
        if (uRes.ok) ubicaciones = uRes.data;
        if (tRes.ok) tours = tRes.data;
        populateUbicaciones();
        populateFilterDestino();
        applyFilters();
      }

      function applyFilters() {
        const searchTerm = searchInput.value.toLowerCase();
        const statusTerm = filterStatus.value;
        const destinoTerm = filterDestino.value;

        const filtered = tours.filter(t => {
          const matchSearch = !searchTerm || t.titulo.toLowerCase().includes(searchTerm) || t.ubicacion?.toLowerCase().includes(searchTerm);
          const matchStatus = !statusTerm || t.estado === statusTerm;
          const matchDestino = !destinoTerm || t.ubicacion_id == destinoTerm;
          return matchSearch && matchStatus && matchDestino;
        });

        tourCount.textContent = `${filtered.length} tour${filtered.length !== 1 ? 's' : ''} encontrado${filtered.length !== 1 ? 's' : ''}`;
        renderList(filtered);
      }

      function renderList(items) {
        if (items.length === 0) {
          listEl.style.display = 'none';
          emptyEl.style.display = 'block';
          return;
        }
        listEl.style.display = 'grid';
        emptyEl.style.display = 'none';

        listEl.innerHTML = items.map(t => {
          const statusText = t.estado === 'activo' ? 'Activo' : 'Inactivo';
          return `
            <div class="tour-card">
              <div class="tour-card-media">
                ${t.imagen_principal ? `<img src="${t.imagen_principal}" alt="${t.titulo}" />` : ''}
                <div class="tour-card-badge status ${t.estado}"><i class="fas ${t.estado === 'activo' ? 'fa-check-circle' : 'fa-times-circle'}"></i> ${statusText}</div>
                ${t.destacado ? `<div class="tour-card-badge featured"><i class="fas fa-star"></i></div>` : ''}
              </div>
              <div class="tour-card-body">
                <h4 class="tour-card-title">${t.titulo}</h4>
                <div class="tour-card-meta"><i class="fas fa-map-marker-alt"></i> ${t.ubicacion} <span>•</span> <i class="fas fa-clock"></i> ${t.duracion}</div>
                <div class="tour-card-price">$${Number(t.precio ?? 0).toFixed(2)}</div>
                <p class="tour-card-desc">${t.descripcion?.slice(0,100) ?? ''}...</p>
                <div class="tour-card-actions">
                  <button data-id="${t.id}" class="editBtn btn-edit"><i class="fas fa-edit"></i> Editar</button>
                  <button data-id="${t.id}" class="delBtn btn-delete"><i class="fas fa-trash"></i> Eliminar</button>
                </div>
              </div>
            </div>
          `;
        }).join('');

        listEl.querySelectorAll('.editBtn').forEach(b=>b.addEventListener('click', ()=>openEditor(b.dataset.id)));
        listEl.querySelectorAll('.delBtn').forEach(b=>b.addEventListener('click', ()=>delItem(b.dataset.id)));
      }

      function populateUbicaciones() {
        const sel = form.querySelector('select[name="ubicacion_id"]');
        sel.innerHTML = ubicaciones.map(u=>`<option value="${u.id}">${u.nombre}</option>`).join('');
      }

      function populateFilterDestino() {
        const sel = filterDestino;
        sel.innerHTML = '<option value="">Todos los destinos</option>' + ubicaciones.map(u=>`<option value="${u.id}">${u.nombre}</option>`).join('');
      }

      function openEditor(id) {
        const data = tours.find(t=>String(t.id)===String(id)) || {};
        const modalTitle = document.getElementById('modalTitle');
        modalTitle.textContent = data.id ? `Editar: ${data.titulo}` : 'Nuevo Tour';

        form.querySelector('input[name="id"]').value = data.id || '';
        form.querySelector('input[name="titulo"]').value = data.titulo || '';
        form.querySelector('textarea[name="descripcion"]').value = data.descripcion || '';
        form.querySelector('input[name="precio"]').value = data.precio ?? '';
        form.querySelector('input[name="duracion"]').value = data.duracion || '';
        form.querySelector('select[name="ubicacion_id"]').value = data.ubicacion_id || (ubicaciones[0]?.id ?? '');
        form.querySelector('textarea[name="incluye"]').value = data.incluye || '';
        form.querySelector('textarea[name="no_incluye"]').value = data.no_incluye || '';
        form.querySelector('textarea[name="itinerario"]').value = data.itinerario || '';
        form.querySelector('input[name="imagen_principal"]').value = data.imagen_principal || '';
        form.querySelector('textarea[name="galeria"]').value = JSON.stringify(data.galeria ?? [], null, 2);
        form.querySelector('input[name="destacado"]').checked = !!data.destacado;
        const estadoVal = data.estado || 'activo';
        form.querySelector(`input[name="estado"][value="${estadoVal}"]`).checked = true;
        openModal();
      }

      function openModal() {
        editor.style.display = 'block';
        modalOverlay.style.display = 'block';
      }

      function closeModal() {
        editor.style.display = 'none';
        modalOverlay.style.display = 'none';
      }

      async function delItem(id) {
        if (!confirm('¿Estás seguro de que deseas eliminar este tour?')) return;
        const res = await api.del(Number(id));
        if (res.ok) await load(); else alert(res.error || 'Error al eliminar');
      }

      form.addEventListener('submit', async (ev) => {
        ev.preventDefault();
        const idVal = form.querySelector('input[name="id"]').value;
        const estadoRadio = Array.from(form.querySelectorAll('input[name="estado"]')).find(r => r.checked);
        const payload = {
          id: idVal ? Number(idVal) : undefined,
          titulo: form.querySelector('input[name="titulo"]').value,
          descripcion: form.querySelector('textarea[name="descripcion"]').value,
          precio: Number(form.querySelector('input[name="precio"]').value || 0),
          duracion: form.querySelector('input[name="duracion"]').value,
          ubicacion_id: Number(form.querySelector('select[name="ubicacion_id"]').value),
          incluye: form.querySelector('textarea[name="incluye"]').value,
          no_incluye: form.querySelector('textarea[name="no_incluye"]').value || null,
          itinerario: form.querySelector('textarea[name="itinerario"]').value || null,
          imagen_principal: form.querySelector('input[name="imagen_principal"]').value || null,
          destacado: form.querySelector('input[name="destacado"]').checked,
          estado: estadoRadio ? estadoRadio.value : 'activo',
        };
        try {
          payload.galeria = JSON.parse(form.querySelector('textarea[name="galeria"]').value || '[]');
        } catch (e) {
          alert('Error: Galería JSON inválido - ' + e.message);
          return;
        }

        let res;
        if (payload.id) {
          res = await api.update(payload);
        } else {
          res = await api.create(payload);
        }
        if (res.ok) { await load(); closeModal(); } else {
          alert('Error al guardar: ' + (res.error || 'Error desconocido'));
        }
      });

      newBtn.addEventListener('click', () => { 
        form.reset();
        form.querySelector('input[name="id"]').value = '';
        form.querySelector('textarea[name="galeria"]').value = '[]';
        openModal();
      });

      cancelBtn.addEventListener('click', closeModal);
      closeBtn.addEventListener('click', closeModal);
      modalOverlay.addEventListener('click', closeModal);
      editor.addEventListener('click', (e) => e.stopPropagation());

      searchInput.addEventListener('input', applyFilters);
      filterStatus.addEventListener('change', applyFilters);
      filterDestino.addEventListener('change', applyFilters);

      // Function to update image preview
      window.updateImagePreview = function(url) {
        const preview = document.getElementById('imagePreview');
        const img = document.getElementById('previewImg');
        if (url && url.trim()) {
          img.src = url;
          preview.style.display = 'block';
          img.onerror = () => { preview.style.display = 'none'; };
        } else {
          preview.style.display = 'none';
        }
      };

      // Media picker integration
      const mediaPicker = document.getElementById('mediaPicker');
      const mediaPickerContent = document.getElementById('mediaPickerContent');
      const mediaPickerClose = document.getElementById('mediaPickerClose');
      const mediaPickerSelect = document.getElementById('mediaPickerSelect');
      const mediaPickerCancel = document.getElementById('mediaPickerCancel');
      let mediaSelectionMode = 'single'; // 'single' or 'multiple'
      let selectedMedia = new Set();

      async function openMediaPicker(mode = 'single') {
        mediaSelectionMode = mode;
        selectedMedia = new Set();
        mediaPickerContent.innerHTML = 'Cargando...';
        mediaPicker.style.display = 'block';
        const res = await fetch('/api/admin/media');
        const payload = await res.json().catch(()=>({ok:false}));
        if (!payload?.ok) { mediaPickerContent.innerHTML = 'Error cargando medios'; return; }
        const items = payload.data || [];
        mediaPickerContent.innerHTML = items.map(i => `
          <div class="picker-item" data-id="${i.id}" data-url="${i.url}">
            <img src="${i.url}" alt="${i.alt_text || ''}" />
            <div class="picker-meta">${i.filename || ''}</div>
          </div>
        `).join('');

        mediaPickerContent.querySelectorAll('.picker-item').forEach(el=>{
          el.addEventListener('click', ()=>{
            const id = el.dataset.id; const url = el.dataset.url;
            if (mediaSelectionMode === 'single') {
              selectedMedia = new Set([JSON.stringify({id, url})]);
              // highlight
              mediaPickerContent.querySelectorAll('.picker-item').forEach(x=>x.classList.remove('selected'));
              el.classList.add('selected');
            } else {
              const key = JSON.stringify({id, url});
              if (selectedMedia.has(key)) { selectedMedia.delete(key); el.classList.remove('selected'); }
              else { selectedMedia.add(key); el.classList.add('selected'); }
            }
          });
        });
      }

      mediaPickerClose?.addEventListener('click', ()=>{ mediaPicker.style.display='none'; });
      mediaPickerCancel?.addEventListener('click', ()=>{ mediaPicker.style.display='none'; });
      mediaPickerSelect?.addEventListener('click', ()=>{
        const arr = Array.from(selectedMedia).map(s=>JSON.parse(s));
        if (mediaSelectionMode === 'single' && arr[0]) {
          // set as imagen_principal
          document.getElementById('imagenPrincipalInput').value = arr[0].url;
          updateImagePreview(arr[0].url);
        } else if (mediaSelectionMode === 'multiple') {
          // append to gallery textarea as JSON array
          const curr = document.getElementById('galeriaTextarea').value || '[]';
          let gallery = [];
          try { gallery = JSON.parse(curr); if (!Array.isArray(gallery)) gallery = []; } catch { gallery = []; }
          const maxOrden = gallery.reduce((m, it)=>Math.max(m, Number(it.orden || 0)), 0);
          let next = maxOrden + 1;
          arr.forEach(it=>{ gallery.push({ imagen: it.url, orden: next++ }); });
          document.getElementById('galeriaTextarea').value = JSON.stringify(gallery, null, 2);
        }
        mediaPicker.style.display='none';
      });

      // Hook up buttons
      const selectPrimaryBtn = document.getElementById('selectPrimaryBtn');
      const openGalleryPickerBtn = document.getElementById('openGalleryPicker');
      selectPrimaryBtn?.addEventListener('click', ()=>openMediaPicker('single'));
      openGalleryPickerBtn?.addEventListener('click', ()=>openMediaPicker('multiple'));

      load();
    </script>
</AdminLayout>
