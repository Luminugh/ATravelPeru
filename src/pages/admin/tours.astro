---
import AdminLayout from "../../layouts/AdminLayout.astro";

const title = "Gestión de Tours AT - Panel Admin";
---

<AdminLayout title={title}>
  <!-- Tours Section -->
  <section class="content-section">
    <div class="section-header">
      <h3>
        <i class="fas fa-map"></i>
        Gestión de Tours AT
      </h3>
      <div class="section-actions">
        <button class="btn btn-primary">
          <i class="fas fa-plus"></i>
          Nuevo Tour
        </button>
        <button class="btn btn-secondary">
          <i class="fas fa-download"></i>
          Exportar
        </button>
      </div>
    </div>

    <div class="search-bar">
      <div class="search-input">
        <i class="fas fa-search search-icon"></i>
        <input type="text" placeholder="Buscar tours..." />
      </div>
      <div class="filter-select">
        <select>
          <option>Todos los estados</option>
          <option>Activo</option>
          <option>Inactivo</option>
          <option>Pendiente</option>
        </select>
      </div>
    </div>

    <table class="data-table">
      <thead>
        <tr>
          <th>Nombre del Tour</th>
          <th>Destino</th>
          <th>Precio</th>
          <th>Duración</th>
          <th>Estado</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><span class="item-name">Machu Picchu Clásico</span></td>
          <td>Cusco - Machupicchu</td>
          <td>$299</td>
          <td>4 días</td>
          <td><span class="item-status active">Activo</span></td>
          <td>
            <div class="item-actions">
              <button class="action-btn edit" title="Editar">
                <i class="fas fa-edit"></i>
              </button>
              <button class="action-btn view" title="Ver">
                <i class="fas fa-eye"></i>
              </button>
              <button class="action-btn delete" title="Eliminar">
                <i class="fas fa-trash"></i>
              </button>
            </div>
          </td>
        </tr>
        <tr>
          <td><span class="item-name">Valle Sagrado</span></td>
          <td>Cusco - Valle Sagrado</td>
          <td>$199</td>
          <td>3 días</td>
          <td><span class="item-status active">Activo</span></td>
          <td>
            <div class="item-actions">
              <button class="action-btn edit" title="Editar">
                <i class="fas fa-edit"></i>
              </button>
              <button class="action-btn view" title="Ver">
                <i class="fas fa-eye"></i>
              </button>
              <button class="action-btn delete" title="Eliminar">
                <i class="fas fa-trash"></i>
              </button>
            </div>
          </td>
        </tr>
        <tr>
          <td><span class="item-name">Selva Amazónica</span></td>
          <td>Iquitos</td>
          <td>$399</td>
          <td>5 días</td>
          <td><span class="item-status inactive">Inactivo</span></td>
          <td>
            <div class="item-actions">
              <button class="action-btn edit" title="Editar">
                <i class="fas fa-edit"></i>
              </button>
              <button class="action-btn view" title="Ver">
                <i class="fas fa-eye"></i>
              </button>
              <button class="action-btn delete" title="Eliminar">
                <i class="fas fa-trash"></i>
              </button>
            </div>
          </td>
        </tr>
      </tbody>
    </table>
  </section>
</AdminLayout>
