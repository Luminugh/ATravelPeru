---
import AdminLayout from "../../layouts/AdminLayout.astro";

export const prerender = true;

const title = "Configuración de WhatsApp";
---

<AdminLayout title={title}>
  <section class="whatsapp-config-page">
    <!-- Hero Section -->
    <div class="whatsapp-hero">
      <div class="whatsapp-hero-copy">
        <div class="whatsapp-badge"><i class="fab fa-whatsapp"></i> Configuración de WhatsApp</div>
        <h1 class="whatsapp-hero-title">Número único de reservas</h1>
        <p class="whatsapp-hero-text">
          Configura el número de WhatsApp que usarán todos los clientes cuando reserven tours desde el catálogo público. Este es un número global para todo el sistema.
        </p>

        <div class="whatsapp-badge-row">
          <span class="whatsapp-badge-pill"><i class="fas fa-phone"></i> Número único global</span>
          <span class="whatsapp-badge-pill"><i class="fas fa-database"></i> Guardado en BD</span>
          <span class="whatsapp-badge-pill"><i class="fas fa-mobile-screen-button"></i> Optimizado para móvil</span>
        </div>

        <div class="whatsapp-actions whatsapp-actions--hero">
          <button type="button" id="editWhatsappBtn" class="whatsapp-action-btn whatsapp-action-btn--primary">
            <i class="fas fa-pen"></i> Configurar
          </button>
          <a href="/admin" class="whatsapp-action-btn whatsapp-action-btn--secondary">
            <i class="fas fa-arrow-left"></i> Volver
          </a>
        </div>
      </div>

      <div class="whatsapp-hero-panel">
        <div class="whatsapp-icon">
          <i class="fab fa-whatsapp"></i>
        </div>
        <div class="whatsapp-status">
          <p class="whatsapp-status-label">Número configurado</p>
          <p class="whatsapp-status-value" id="whatsappStatusValue">Cargando...</p>
        </div>
      </div>
    </div>

    <!-- Loading State -->
    <div id="whatsappLoading" class="whatsapp-card" hidden>
      <div style="display: flex; align-items: center; gap: 12px; justify-content: center;">
        <i class="fas fa-spinner fa-spin" style="font-size: 20px; color: #10b981;"></i>
        <span>Cargando configuración...</span>
      </div>
    </div>

    <!-- Content -->
    <div id="whatsappContent" class="whatsapp-grid">
      <!-- Config Card: Phone -->
      <article class="whatsapp-card whatsapp-card--phone whatsapp-card--full">
        <div class="whatsapp-card-header">
          <div>
            <h3><i class="fas fa-phone"></i> Número de WhatsApp Global</h3>
            <p class="whatsapp-note">Este número se usará en todas las reservas del catálogo público. Un único número para todo el sistema.</p>
          </div>
          <span class="whatsapp-status-chip" id="phoneStatusChip">
            <i class="fas fa-circle-exclamation"></i> Por configurar
          </span>
        </div>

        <div class="whatsapp-phone-display" id="phoneDisplay">
          <div class="phone-info">
            <span class="phone-label">Número actual:</span>
            <p class="phone-value" id="phonePreview">-</p>
          </div>
        </div>

        <form id="phoneEditForm" class="whatsapp-edit-form" hidden>
          <div class="form-group">
            <label for="whatsappPhoneInput">Ingresa el número de WhatsApp</label>
            <input
              id="whatsappPhoneInput"
              type="tel"
              name="whatsapp_phone"
              placeholder="Ej: 987654321 o +51987654321"
              maxlength="20"
              required
            />
            <p class="form-hint">Ingresa solo dígitos. Se aceptan números con o sin el código de país. Mínimo 9 dígitos.</p>
          </div>

          <div class="whatsapp-edit-actions">
            <button type="submit" class="whatsapp-action-btn whatsapp-action-btn--primary">
              <i class="fas fa-save"></i> Guardar número
            </button>
            <button type="button" id="cancelPhoneBtn" class="whatsapp-action-btn whatsapp-action-btn--secondary">
              <i class="fas fa-xmark"></i> Cancelar
            </button>
          </div>
        </form>

        <button type="button" id="editPhoneBtn" class="whatsapp-card-action" hidden>
          <i class="fas fa-pen"></i> Editar
        </button>
      </article>

      <!-- Info Card: Preview -->
      <article class="whatsapp-card whatsapp-card--preview whatsapp-card--full">
        <div class="whatsapp-card-header">
          <div>
            <h3><i class="fas fa-eye"></i> Vista Previa</h3>
            <p class="whatsapp-note">Así verán los clientes el número cuando reserven desde el catálogo.</p>
          </div>
        </div>

        <div class="whatsapp-preview-box">
          <div class="whatsapp-phone-mockup">
            <div class="phone-header">
              <span class="phone-time">13:45</span>
              <div class="phone-status">
                <i class="fas fa-signal"></i>
                <i class="fas fa-wifi"></i>
                <i class="fas fa-battery-three-quarters"></i>
              </div>
            </div>

            <div class="phone-chat">
              <div class="chat-message chat-message-yours">
                <p id="previewChatMessage">Hola, quiero reservar Machu Picchu Express (3 dias) por S/ 1,300</p>
                <span class="message-time">13:45</span>
              </div>
            </div>

            <div class="phone-input-area">
              <input type="text" placeholder="Escribe un mensaje..." disabled />
              <button type="button" disabled><i class="fas fa-paper-plane"></i></button>
            </div>
          </div>
        </div>
      </article>
    </div>

    <!-- Error State -->
    <div id="whatsappError" class="whatsapp-card whatsapp-error-card" hidden></div>
  </section>

  <script>
    // @ts-nocheck

    function getEl(id: string) {
      return document.getElementById(id);
    }

    let whatsappState = {
      phone: '',
    };

    function formatPhoneForDisplay(phone: string) {
      if (!phone) return 'No configurado';
      const cleaned = phone.replace(/\D/g, '');
      if (cleaned.length >= 9) {
        return `+51 ${cleaned.slice(-9)}`;
      }
      return phone;
    }

    function setPhoneEditMode(enabled: boolean) {
      const form = getEl('phoneEditForm');
      const editBtn = getEl('editPhoneBtn');
      const input = getEl('whatsappPhoneInput');

      if (form) form.hidden = !enabled;
      if (editBtn) editBtn.hidden = enabled;
      if (enabled && input && input instanceof HTMLInputElement) {
        input.focus();
      }
    }

    function updatePreview() {
      const phoneChip = getEl('phoneStatusChip');

      if (phoneChip) {
        if (whatsappState.phone) {
          phoneChip.innerHTML = '<i class="fas fa-circle-check"></i> Configurado';
          phoneChip.classList.remove('error');
        } else {
          phoneChip.innerHTML = '<i class="fas fa-circle-exclamation"></i> Por configurar';
          phoneChip.classList.add('error');
        }
      }
    }

    async function loadConfig() {
      console.log('[WhatsApp Config] Iniciando carga...');
      const loading = getEl('whatsappLoading');
      const content = getEl('whatsappContent');
      const error = getEl('whatsappError');

      try {
        // Fetch with 5-second timeout
        const controller = new AbortController();
        const timeout = setTimeout(() => controller.abort(), 5000);

        console.log('[WhatsApp Config] Fetching /api/admin/app-config...');
        const response = await fetch('/api/admin/app-config', { signal: controller.signal });
        clearTimeout(timeout);

        console.log('[WhatsApp Config] Response status:', response.status);
        const payload = await response.json();
        console.log('[WhatsApp Config] Payload:', payload);

        if (!response.ok || !payload?.ok) {
          throw new Error(payload?.error || 'No fue posible cargar la configuración');
        }

        whatsappState.phone = payload.phone || '';
        console.log('[WhatsApp Config] Phone:', whatsappState.phone);

        // Render config into available elements
        const phonePreview = getEl('phonePreview');
        const phoneInput = getEl('whatsappPhoneInput');
        const statusValue = getEl('whatsappStatusValue');

        if (phonePreview) phonePreview.textContent = formatPhoneForDisplay(whatsappState.phone);
        if (statusValue) statusValue.textContent = whatsappState.phone ? formatPhoneForDisplay(whatsappState.phone) : 'Sin configurar';
        if (phoneInput && phoneInput instanceof HTMLInputElement) phoneInput.value = whatsappState.phone;

        updatePreview();

        // Mark hero as configured when phone exists
        const heroPanel = document.querySelector('.whatsapp-hero-panel');
        const editWhatsappBtn = getEl('editWhatsappBtn');
        const statusLabelEl = document.querySelector('.whatsapp-hero .whatsapp-status-label');
        if (whatsappState.phone) {
          if (heroPanel instanceof HTMLElement) heroPanel.classList.add('configured');
          if (editWhatsappBtn instanceof HTMLElement) editWhatsappBtn.classList.add('configured');
          if (statusLabelEl instanceof HTMLElement) statusLabelEl.textContent = 'Configurado';
        } else {
          if (heroPanel instanceof HTMLElement) heroPanel.classList.remove('configured');
          if (editWhatsappBtn instanceof HTMLElement) editWhatsappBtn.classList.remove('configured');
          if (statusLabelEl instanceof HTMLElement) statusLabelEl.textContent = 'Número configurado';
        }

        // Hide loading and show content using display:none (more reliable than hidden)
        console.log('[WhatsApp Config] Hiding loading div, showing content...');
        if (loading) {
          loading.style.display = 'none';
          loading.hidden = true;
        }
        if (content) {
          content.style.display = 'block';
          content.hidden = false;
        }
        console.log('[WhatsApp Config] Carga completada');
      } catch (err) {
        console.error('[WhatsApp Config] Error:', err);
        // Always hide loading even on error
        if (loading) {
          loading.style.display = 'none';
          loading.hidden = true;
        }
        if (content) {
          content.style.display = 'block';
          content.hidden = false;
        }
        if (error) {
          error.hidden = false;
          error.innerHTML = `<strong>Error:</strong> ${err instanceof Error ? err.message : 'No fue posible cargar la configuración'}`;
        }
      }
    }

    async function savePhone(ev) {
      ev.preventDefault();
      const input = getEl('whatsappPhoneInput');
      const value = input && input instanceof HTMLInputElement ? input.value.trim() : '';

      if (!value) {
        alert('El número de teléfono no puede estar vacío.');
        return;
      }

      const cleaned = value.replace(/\D/g, '');
      if (cleaned.length < 9) {
        alert('El número debe tener al menos 9 dígitos.');
        return;
      }

      try {
        const response = await fetch('/api/admin/app-config', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ phone: cleaned }),
        });

        const payload = await response.json();

        if (!response.ok || !payload?.ok) {
          throw new Error(payload?.error || 'Error al guardar el número');
        }

        whatsappState.phone = cleaned;
        updatePreview();
        setPhoneEditMode(false);

        const phonePreview = getEl('phonePreview');
        const statusValue = getEl('whatsappStatusValue');
        if (phonePreview) {
          phonePreview.textContent = formatPhoneForDisplay(cleaned);
        }
        if (statusValue) {
          statusValue.textContent = formatPhoneForDisplay(cleaned);
        }
      } catch (err) {
        alert(`Error: ${err instanceof Error ? err.message : 'Ocurrió un error'}`);
      }
    }

    // Initialize when page loads
    loadConfig();

    // Event Listeners
    const editWhatsappBtn = getEl('editWhatsappBtn');
    if (editWhatsappBtn) {
      editWhatsappBtn.addEventListener('click', () => {
        setPhoneEditMode(true);
      });
    }

    const editPhoneBtn = getEl('editPhoneBtn');
    if (editPhoneBtn) {
      editPhoneBtn.addEventListener('click', () => {
        setPhoneEditMode(true);
      });
    }

    const cancelPhoneBtn = getEl('cancelPhoneBtn');
    if (cancelPhoneBtn) {
      cancelPhoneBtn.addEventListener('click', () => {
        setPhoneEditMode(false);
      });
    }

    const phoneForm = getEl('phoneEditForm');
    if (phoneForm && phoneForm instanceof HTMLFormElement) {
      phoneForm.addEventListener('submit', savePhone);
    }
  </script>
</AdminLayout>
