---
import AppLayout from "../layouts/AppLayout.astro";

const title = "Tours AT - Recorridos Turísticos";
---

<AppLayout title={title}>
<!-- Hero Section Tours AT -->
    <section class="hero-section hero-secondary">
        <div class="hero-background">
            <video autoplay muted loop class="hero-video">
                <source src="/assets/videos/Video1.mp4" type="video/mp4">
                Tu navegador no soporta videos.
            </video>
        </div>
        <div class="hero-overlay"></div>
        <div class="hero-content">
            <div class="hero-badge">Experiencias únicas garantizadas</div>
            <h2 class="hero-title">Recorridos Turísticos Tours AT</h2>
            <p class="hero-subtitle">Descubre nuestros recorridos predeterminados diseñados especialmente para enamorarte del Perú</p>
            
            <div class="hero-features">
                <div class="hero-feature-item">
                    <i class="fas fa-route feature-icon"></i>
                    <span class="feature-text">25+ Rutas</span>
                </div>
                <div class="hero-feature-item">
                    <i class="fas fa-calendar-days feature-icon"></i>
                    <span class="feature-text">Salidas Diarias</span>
                </div>
                <div class="hero-feature-item">
                    <i class="fas fa-thumbs-up feature-icon"></i>
                    <span class="feature-text">98% Rating</span>
                </div>
            </div>

            <div class="hero-actions">
                <a class="btn-hero-primary" href="#tours-content">Ver Todos</a>
                <button class="btn-hero-secondary">Consultar Disponibilidad</button>
            </div>
        </div>
    </section>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        
        <!-- Filtros Section -->
        <section class="filters-section mb-12">
            <h2 class="text-2xl font-bold mb-8 text-gray-900">Encuentra tu Recorrido Ideal</h2>
            <div class="filters-container">
                <div class="filter-group">
                    <label class="filter-label">Destino</label>
                    <select class="filter-select">
                        <option>Todos los destinos</option>
                        <option>Machu Picchu</option>
                        <option>Cusco</option>
                        <option>Sagrado</option>
                        <option>Selva Peruana</option>
                        <option>Lima</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label class="filter-label">Duración</label>
                    <select class="filter-select">
                        <option>Cualquier duración</option>
                        <option>1 día</option>
                        <option>2-3 días</option>
                        <option>4-5 días</option>
                        <option>6+ días</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label class="filter-label">Dificultad</label>
                    <select class="filter-select">
                        <option>Cualquier nivel</option>
                        <option>Fácil</option>
                        <option>Moderado</option>
                        <option>Difícil</option>
                        <option>Extremo</option>
                    </select>
                </div>
                <button class="btn-filter-search">Buscar</button>
            </div>
        </section>

        <!-- Tours Grid Section -->
        <section id="tours-content" class="tours-section">
            <h2 class="section-title mb-12">Nuestros Recorridos Destacados</h2>
            <div class="tours-grid">
                
                <!-- Tour 1 -->
                <div class="tour-card">
                    <div class="tour-image">
                        <img src="https://via.placeholder.com/400x250/FF6B6B/FFFFFF?text=Machu+Picchu" alt="Machu Picchu Express">
                        <div class="tour-badge tour-badge-popular">Popular</div>
                    </div>
                    <div class="tour-content">
                        <h3 class="tour-title">Machu Picchu Express</h3>
                        <div class="tour-meta">
                            <span class="tour-duration"><i class="fas fa-calendar-days"></i> 2 días</span>
                            <span class="tour-difficulty difficulty-moderado">Moderado</span>
                        </div>
                        <p class="tour-description">Explora la maravilla del mundo en una experiencia inolvidable. Incluye tren de lujo, guía experto y alojamiento en Aguas Calientes.</p>
                        <div class="tour-features">
                            <span class="feature-tag">Transporte incluido</span>
                            <span class="feature-tag">Guía bilingüe</span>
                            <span class="feature-tag">Cena incluida</span>
                        </div>
                        <div class="tour-footer">
                            <div class="tour-price">
                                <span class="price-label">Desde</span>
                                <span class="price-value">S/ 1,200</span>
                            </div>
                            <button class="btn-tour-reserve" onclick="showNotification('Solicitud de reserva enviada', 'success')">Reservar</button>
                        </div>
                    </div>
                </div>

                <!-- Tour 2 -->
                <div class="tour-card">
                    <div class="tour-image">
                        <img src="https://via.placeholder.com/400x250/4ECDC4/FFFFFF?text=Valle+Sagrado" alt="Valle Sagrado">
                        <div class="tour-badge tour-badge-new">Nuevo</div>
                    </div>
                    <div class="tour-content">
                        <h3 class="tour-title">Valle Sagrado de los Incas</h3>
                        <div class="tour-meta">
                            <span class="tour-duration"><i class="fas fa-calendar-days"></i> 1 día</span>
                            <span class="tour-difficulty difficulty-facil">Fácil</span>
                        </div>
                        <p class="tour-description">Conoce los pueblos mágicos, mercados tradicionales y ruinas incaicas en el corazón del Valle Sagrado.</p>
                        <div class="tour-features">
                            <span class="feature-tag">Mercado local</span>
                            <span class="feature-tag">Almuerzo típico</span>
                            <span class="feature-tag">Fotos épicas</span>
                        </div>
                        <div class="tour-footer">
                            <div class="tour-price">
                                <span class="price-label">Desde</span>
                                <span class="price-value">S/ 450</span>
                            </div>
                            <button class="btn-tour-reserve" onclick="showNotification('Solicitud de reserva enviada', 'success')">Reservar</button>
                        </div>
                    </div>
                </div>

                <!-- Tour 3 -->
                <div class="tour-card">
                    <div class="tour-image">
                        <img src="https://via.placeholder.com/400x250/95E1D3/FFFFFF?text=Selva+Peruana" alt="Selva Peruana">
                    </div>
                    <div class="tour-content">
                        <h3 class="tour-title">Aventura en la Selva Amazónica</h3>
                        <div class="tour-meta">
                            <span class="tour-duration"><i class="fas fa-calendar-days"></i> 4 días</span>
                            <span class="tour-difficulty difficulty-dificil">Difícil</span>
                        </div>
                        <p class="tour-description">Inmersión total en la selva peruana: avistamiento de fauna, comunidades nativas y navegación en el río Amazonas.</p>
                        <div class="tour-features">
                            <span class="feature-tag">All-inclusive</span>
                            <span class="feature-tag">Lodge eco-amigable</span>
                            <span class="feature-tag">Guía naturalista</span>
                        </div>
                        <div class="tour-footer">
                            <div class="tour-price">
                                <span class="price-label">Desde</span>
                                <span class="price-value">S/ 2,100</span>
                            </div>
                            <button class="btn-tour-reserve" onclick="showNotification('Solicitud de reserva enviada', 'success')">Reservar</button>
                        </div>
                    </div>
                </div>

                <!-- Tour 4 -->
                <div class="tour-card">
                    <div class="tour-image">
                        <img src="https://via.placeholder.com/400x250/F38181/FFFFFF?text=Cusco+Colonial" alt="Cusco Colonial">
                        <div class="tour-badge tour-badge-top">Top Rating</div>
                    </div>
                    <div class="tour-content">
                        <h3 class="tour-title">Cusco Colonial y Arqueología</h3>
                        <div class="tour-meta">
                            <span class="tour-duration"><i class="fas fa-calendar-days"></i> 3 días</span>
                            <span class="tour-difficulty difficulty-facil">Fácil</span>
                        </div>
                        <p class="tour-description">Recorre la capital inca: Qoricancha, Sacsayhuamán, Plaza de Armas y barrios coloniales con historia milenaria.</p>
                        <div class="tour-features">
                            <span class="feature-tag">Museo incluido</span>
                            <span class="feature-tag">Desayunos</span>
                            <span class="feature-tag">Entradas pagadas</span>
                        </div>
                        <div class="tour-footer">
                            <div class="tour-price">
                                <span class="price-label">Desde</span>
                                <span class="price-value">S/ 850</span>
                            </div>
                            <button class="btn-tour-reserve" onclick="showNotification('Solicitud de reserva enviada', 'success')">Reservar</button>
                        </div>
                    </div>
                </div>

                <!-- Tour 5 -->
                <div class="tour-card">
                    <div class="tour-image">
                        <img src="https://via.placeholder.com/400x250/AA96DA/FFFFFF?text=Lima+Gastronómica" alt="Lima Gastronómica">
                    </div>
                    <div class="tour-content">
                        <h3 class="tour-title">Lima Gastronómica y Cultural</h3>
                        <div class="tour-meta">
                            <span class="tour-duration"><i class="fas fa-calendar-days"></i> 2 días</span>
                            <span class="tour-difficulty difficulty-facil">Fácil</span>
                        </div>
                        <p class="tour-description">Explora la capital peruana: gastronomía de clase mundial, museos nacionales y miradores con vistas espectaculares.</p>
                        <div class="tour-features">
                            <span class="feature-tag">4 restaurantes</span>
                            <span class="feature-tag">Tour gastronómico</span>
                            <span class="feature-tag">Transporte 5 estrellas</span>
                        </div>
                        <div class="tour-footer">
                            <div class="tour-price">
                                <span class="price-label">Desde</span>
                                <span class="price-value">S/ 950</span>
                            </div>
                            <button class="btn-tour-reserve" onclick="showNotification('Solicitud de reserva enviada', 'success')">Reservar</button>
                        </div>
                    </div>
                </div>

                <!-- Tour 6 -->
                <div class="tour-card">
                    <div class="tour-image">
                        <img src="https://via.placeholder.com/400x250/FCBAD3/FFFFFF?text=Lago+Titicaca" alt="Lago Titicaca">
                    </div>
                    <div class="tour-content">
                        <h3 class="tour-title">Isla de Taquile - Lago Titicaca</h3>
                        <div class="tour-meta">
                            <span class="tour-duration"><i class="fas fa-calendar-days"></i> 2 días</span>
                            <span class="tour-difficulty difficulty-moderado">Moderado</span>
                        </div>
                        <p class="tour-description">Vive la experiencia única de las Islas flotantes, tejidos ancestrales y la magia del lago más alto del mundo.</p>
                        <div class="tour-features">
                            <span class="feature-tag">Bote turístico</span>
                            <span class="feature-tag">Casa local</span>
                            <span class="feature-tag">Artesanías</span>
                        </div>
                        <div class="tour-footer">
                            <div class="tour-price">
                                <span class="price-label">Desde</span>
                                <span class="price-value">S/ 680</span>
                            </div>
                            <button class="btn-tour-reserve" onclick="showNotification('Solicitud de reserva enviada', 'success')">Reservar</button>
                        </div>
                    </div>
                </div>

            </div>
        </section>

        <!-- Why Choose Tours AT Section -->
        <section class="why-choose-section mt-20">
            <h2 class="section-title mb-12">¿Por qué elegir Tours AT?</h2>
            <div class="why-choose-grid">
                <div class="why-choose-card">
                    <i class="fas fa-shield-alt why-choose-icon"></i>
                    <h3 class="why-choose-title">100% Asegurado</h3>
                    <p class="why-choose-text">Todos nuestros tours están completamente asegurados. Viajar con seguridad es nuestra prioridad.</p>
                </div>
                <div class="why-choose-card">
                    <i class="fas fa-users-class why-choose-icon"></i>
                    <h3 class="why-choose-title">Guías Expertos</h3>
                    <p class="why-choose-text">Nuestros guías son locales certificados con años de experiencia en cada ruta.</p>
                </div>
                <div class="why-choose-card">
                    <i class="fas fa-utensils why-choose-icon"></i>
                    <h3 class="why-choose-title">Comida Incluida</h3>
                    <p class="why-choose-text">Disfruta de la auténtica gastronomía peruana en cada recorrido que realizamos.</p>
                </div>
                <div class="why-choose-card">
                    <i class="fas fa-redo why-choose-icon"></i>
                    <h3 class="why-choose-title">Cancelación Gratuita</h3>
                    <p class="why-choose-text">Cancela tu reserva hasta 48 horas antes sin cargos adicionales.</p>
                </div>
                <div class="why-choose-card">
                    <i class="fas fa-headset why-choose-icon"></i>
                    <h3 class="why-choose-title">Soporte 24/7</h3>
                    <p class="why-choose-text">Equipo disponible en todo momento durante tu viaje para cualquier necesidad.</p>
                </div>
                <div class="why-choose-card">
                    <i class="fas fa-star why-choose-icon"></i>
                    <h3 class="why-choose-title">Experiencias Premium</h3>
                    <p class="why-choose-text">Acceso exclusivo a lugares no turísticos y experiencias auténticas únicamente en Tours AT.</p>
                </div>
            </div>
        </section>

        <!-- CTA Section -->
        <section class="cta-section mt-20 bg-gradient-to-r from-purple-600 to-purple-500 rounded-2xl px-8 py-12 text-white">
            <div class="max-w-2xl mx-auto text-center">
                <h2 class="text-3xl font-bold mb-4">¿Listo para vivir una aventura?</h2>
                <p class="text-lg mb-8 text-purple-100">Con Tours AT, cada recorrido es una historia que deseará contar una y otra vez</p>
                <button class="btn-cta-primary" onclick="showNotification('Te contactaremos pronto', 'success')">Reservar Ahora</button>
            </div>
        </section>

    </main>
</AppLayout>


