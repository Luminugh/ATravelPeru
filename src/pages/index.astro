---
import AppLayout from "../layouts/AppLayout.astro";

export const prerender = true;
---

<AppLayout title={"ATRAVEL - Tu próximo viaje espera"}>
  <section class="hero-section hero-secondary hero-home-align">
    <div class="hero-background">
      <video autoplay muted loop class="hero-video">
        <source src="/assets/videos/Video1.mp4" type="video/mp4" />
        Tu navegador no soporta videos.
      </video>
    </div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <div class="hero-badge">Viajes increíbles te esperan</div>
      <h2 class="hero-title">Descubre el Perú sin límites</h2>
      <p class="hero-subtitle">Empieza aquí: toca Ver Tours y elige tu siguiente viaje en un solo paso</p>
      <div class="hero-features">
        <div class="hero-feature-item">
          <i class="fas fa-globe feature-icon"></i>
          <span class="feature-text">150+ Destinos</span>
        </div>
        <div class="hero-feature-item">
          <i class="fas fa-star feature-icon"></i>
          <span class="feature-text">5 Estrellas</span>
        </div>
        <div class="hero-feature-item">
          <i class="fas fa-users feature-icon"></i>
          <span class="feature-text">50K+ Viajeros</span>
        </div>
      </div>
      <div class="hero-actions">
        <a class="btn-hero-primary" href="/tours#tours-content">Ver Tours</a>
        <a class="btn-hero-secondary" href="/tours#tours-content">Reservar ahora</a>
      </div>
    </div>
  </section>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <section class="features-section">
      <h2 class="features-title">¿Por qué elegir ATRAVEL?</h2>
      <div class="features-grid">
        <div class="feature-card">
          <i class="fas fa-coins feature-card-icon"></i>
          <h3 class="feature-heading">Mejores Precios</h3>
          <p class="feature-text">Garantizamos los precios más competitivos sin comprometer la calidad de tu viaje</p>
        </div>
        <div class="feature-card">
          <i class="fas fa-lock feature-card-icon"></i>
          <h3 class="feature-heading">100% Seguro</h3>
          <p class="feature-text">Todas nuestras agencias son certificadas y tus viajes están asegurados</p>
        </div>
        <div class="feature-card">
          <i class="fas fa-headset feature-card-icon"></i>
          <h3 class="feature-heading">Soporte 24/7</h3>
          <p class="feature-text">Equipo disponible en todo momento durante tu experiencia de viaje</p>
        </div>
        <div class="feature-card">
          <i class="fas fa-check-circle feature-card-icon"></i>
          <h3 class="feature-heading">Verificado</h3>
          <p class="feature-text">Miles de viajeros satisfechos nos recomiendan cada año</p>
        </div>
      </div>
    </section>
  </main>

</AppLayout>

<style>
/* Hero & features styles: improved layout + full-viewport video */
.hero-section{position:relative;width:100%;height:100vh;min-height:600px;display:flex;align-items:center;justify-content:center;overflow:hidden}
.hero-background{position:absolute;inset:0;overflow:hidden;z-index:0}
.hero-video{position:absolute;left:50%;top:50%;width:100%;height:100%;min-width:1200px;min-height:600px;transform:translate(-50%,-50%);object-fit:cover}
.hero-overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,0,0,0.35) 0%,rgba(0,0,0,0.55) 60%);mix-blend-mode:multiply;z-index:1}
.hero-content{position:relative;z-index:2;color:#fff;padding:48px 20px;text-align:center;max-width:1100px;margin:0 16px}
.hero-badge{display:inline-block;background:rgba(34,197,94,0.12);padding:8px 18px;border-radius:999px;margin-bottom:18px;font-weight:600;color:#d1fae5}
.hero-title{font-size:clamp(32px,6vw,64px);line-height:1.02;margin:12px 0;text-shadow:0 6px 20px rgba(3,7,18,0.6)}
.hero-subtitle{margin-bottom:22px;color:rgba(255,255,255,0.92);font-size:18px;max-width:820px;margin-left:auto;margin-right:auto}
.hero-features{display:flex;gap:18px;justify-content:center;flex-wrap:wrap;margin:18px 0}
.hero-feature-item{display:flex;align-items:center;gap:8px;background:rgba(255,255,255,0.06);padding:10px 14px;border-radius:10px}
.feature-icon{font-size:18px;color:#bbf7d0}
.feature-text{color:#e6ffef;font-weight:600}
.hero-actions{margin-top:22px;display:flex;gap:12px;justify-content:center}
.hero-actions .btn-hero-primary,.hero-actions .btn-hero-secondary{margin:0;padding:12px 22px;border-radius:12px;text-decoration:none;font-weight:700}
.btn-hero-primary{background:linear-gradient(135deg,#22c55e,#16a34a);color:#fff;box-shadow:0 6px 22px rgba(16,185,129,0.18)}
.btn-hero-secondary{background:rgba(255,255,255,0.12);color:#fff;border:1px solid rgba(255,255,255,0.08)}

.features-section{padding:48px 0}
.features-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:24px}
.feature-card{background:#fff;padding:24px;border-radius:12px;text-align:center;box-shadow:0 6px 20px rgba(2,6,23,0.04)}
.feature-card-icon{font-size:36px;color:#16a34a;margin-bottom:12px}
.feature-heading{font-weight:800;margin-bottom:6px}
.feature-text{color:#6b7280}

@media (max-width: 768px){
  .hero-section{height:78vh;min-height:520px}
  .hero-content{padding:28px}
  .hero-title{font-size:28px}
}

</style>
