---
import AppLayout from "../layouts/AppLayout.astro";
import { homePageConfig } from "../lib/site-config";

const title = homePageConfig.title;
---

<AppLayout title={title}>
<!-- Hero Section Mejorado -->
    <section class="hero-section hero-secondary hero-home-align">
        <div class="hero-background">
            <video autoplay muted loop class="hero-video">
                <source src="/assets/videos/Video1.mp4" type="video/mp4">
                Tu navegador no soporta videos.
            </video>
        </div>
        <div class="hero-overlay"></div>
        <div class="hero-content">
            <div class="hero-badge">{homePageConfig.heroBadge}</div>
            <h2 class="hero-title">{homePageConfig.heroTitle}</h2>
            <p class="hero-subtitle">{homePageConfig.heroSubtitle}</p>
            
            <div class="hero-features">
                {homePageConfig.heroFeatures.map((feature) => (
                    <div class="hero-feature-item">
                        <i class={`${feature.icon} feature-icon`}></i>
                        <span class="feature-text">{feature.label}</span>
                    </div>
                ))}
            </div>

            <div class="hero-actions">
                <a class="btn-hero-primary" href={homePageConfig.primaryAction.href}>{homePageConfig.primaryAction.label}</a>
                <a class="btn-hero-secondary" href={homePageConfig.secondaryAction.href}>{homePageConfig.secondaryAction.label}</a>
            </div>
        </div>
    </section>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        
        <!-- Features Section -->
        <section class="features-section">
            <h2 class="features-title">{homePageConfig.featuresTitle}</h2>
            <div class="features-grid">
                {homePageConfig.featureCards.map((card) => (
                    <div class="feature-card">
                        <i class={`${card.icon} feature-card-icon`}></i>
                        <h3 class="feature-heading">{card.title}</h3>
                        <p class="feature-text">{card.text}</p>
                    </div>
                ))}
            </div>
        </section>

    </main>
</AppLayout>

