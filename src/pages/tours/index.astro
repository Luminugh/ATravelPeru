---
import AppLayout from "../../layouts/AppLayout.astro";
import { getToursCatalog } from "../../lib/catalog";
import DiagnosticPanel from "../../components/DiagnosticPanel.astro";
import { contactConfig, toursPageConfig } from "../../lib/site-config";
import { faWhatsapp } from "@fortawesome/free-brands-svg-icons";

const title = toursPageConfig.title;
const whatsappPath = Array.isArray(faWhatsapp.icon[4]) ? faWhatsapp.icon[4].join(" ") : faWhatsapp.icon[4];
const whatsappViewBox = `0 0 ${faWhatsapp.icon[0]} ${faWhatsapp.icon[1]}`;
const whatsappDigits = contactConfig.whatsappDigits;

const { items: toursAtData, error: toursLoadError, source: toursSource } = await getToursCatalog();
---

<AppLayout title={title}>
    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        
        <!-- Tours Grid Section -->
        <section id="tours-content" class="tours-section">
            <h2 class="section-title mb-12">{toursPageConfig.sectionTitle}</h2>
            {toursAtData.length === 0 && (
                <>
                    <div class="tour-empty-state">
                        <h3>No se encontraron tours para mostrar</h3>
                        <p>Fuente consultada: {toursSource}</p>
                        {toursLoadError && <p>Error detectado: {toursLoadError}</p>}
                        <p>Confirma que existan filas activas en la base de datos para mostrar el catálogo.</p>
                    </div>
                    <DiagnosticPanel />
                </>
            )}
            <div class="tours-summary-grid">
                {toursAtData.map((tour) => (
                    <article class="tour-summary-card" data-tour-id={tour.id}>
                        <div class="summary-image-wrap">
                            <img src={tour.imagen_principal} alt={tour.titulo} class="summary-image" loading="lazy" />
                            <div class="summary-badges">
                                {tour.destacado && <span class="summary-badge destacado">Destacado</span>}
                                <span class={`summary-badge estado ${tour.estado}`}>{tour.estado}</span>
                            </div>
                        </div>
                        <div class="summary-content">
                            <h3 class="summary-title">{tour.titulo}</h3>
                            <p class="summary-meta"><i class="fas fa-location-dot"></i> {tour.ubicacion} · <i class="fas fa-clock"></i> {tour.duracion}</p>
                            <p class="summary-description">{tour.descripcion}</p>
                            <div class="summary-footer">
                                <span class="summary-price">{tour.precio}</span>
                                <button class="btn-summary-open" type="button" data-open-tour={tour.id} disabled={tour.estado !== "activo"}>
                                    {tour.estado === "activo" ? "Ver detalles" : "No disponible"}
                                </button>
                            </div>
                        </div>
                    </article>
                ))}
            </div>
        </section>

        <!-- Why Choose Tours AT Section -->
        <section class="why-choose-section mt-20">
            <h2 class="section-title mb-12">{toursPageConfig.whyChooseTitle}</h2>
            <div class="why-choose-grid">
                {toursPageConfig.whyChooseCards.map((card) => (
                    <div class="why-choose-card">
                        <i class={`${card.icon} why-choose-icon`}></i>
                        <h3 class="why-choose-title">{card.title}</h3>
                        <p class="why-choose-text">{card.text}</p>
                    </div>
                ))}
            </div>
        </section>

    </main>

    <div id="tourDetailModal" class="tour-detail-modal" hidden>
        <div class="tour-detail-backdrop" data-close-modal></div>
        <div class="tour-detail-window" role="dialog" aria-modal="true" aria-labelledby="tourDetailTitle">
            <button type="button" class="tour-detail-close" data-close-modal aria-label="Cerrar ventana">
                <i class="fas fa-xmark"></i>
            </button>

            <div class="tour-detail-header">
                <img id="tourDetailInternalImage" src="" alt="Imagen detalle" class="tour-detail-internal-image" />
                <div class="tour-detail-title-wrap">
                    <h3 id="tourDetailTitle" class="tour-detail-title"></h3>
                    <p id="tourDetailMeta" class="tour-detail-meta"></p>
                    <div class="tour-detail-badges">
                        <span id="tourDetailEstado" class="summary-badge estado"></span>
                        <span id="tourDetailDestacado" class="summary-badge destacado" hidden>Destacado</span>
                    </div>
                </div>
            </div>

            <div class="tour-detail-body">
                <p id="tourDetailDescripcion" class="tour-detail-text"></p>

                <div class="tour-detail-block">
                    <h4>Incluye</h4>
                    <p id="tourDetailIncluye"></p>
                </div>

                <div class="tour-detail-block" id="tourDetailNoIncluyeWrap">
                    <h4>No incluye</h4>
                    <p id="tourDetailNoIncluye"></p>
                </div>

                <div class="tour-detail-block" id="tourDetailItinerarioWrap">
                    <h4>Itinerario</h4>
                    <p id="tourDetailItinerario"></p>
                </div>

                <div class="tour-detail-block">
                    <h4>Galería</h4>
                    <div id="tourDetailGallery" class="tour-detail-gallery"></div>
                </div>
            </div>

            <div class="tour-detail-footer">
                <strong id="tourDetailPrice" class="tour-detail-price"></strong>
                <button type="button" id="tourDetailReserve" class="btn-tour-reserve-modal">
                    <svg class="btn-tour-reserve-icon" viewBox={whatsappViewBox} aria-hidden="true" focusable="false">
                        <path d={whatsappPath}></path>
                    </svg>
                    Reservar este tour
                </button>
            </div>
        </div>
    </div>

    <script define:vars={{ toursAtData, whatsappDigits }}>
        const modal = document.getElementById('tourDetailModal');
        const titleEl = document.getElementById('tourDetailTitle');
        const metaEl = document.getElementById('tourDetailMeta');
        const estadoEl = document.getElementById('tourDetailEstado');
        const destacadoEl = document.getElementById('tourDetailDestacado');
        const descripcionEl = document.getElementById('tourDetailDescripcion');
        const incluyeEl = document.getElementById('tourDetailIncluye');
        const noIncluyeWrapEl = document.getElementById('tourDetailNoIncluyeWrap');
        const noIncluyeEl = document.getElementById('tourDetailNoIncluye');
        const itinerarioWrapEl = document.getElementById('tourDetailItinerarioWrap');
        const itinerarioEl = document.getElementById('tourDetailItinerario');
        const galleryEl = document.getElementById('tourDetailGallery');
        const priceEl = document.getElementById('tourDetailPrice');
        const reserveBtn = document.getElementById('tourDetailReserve');
        const internalImageEl = document.getElementById('tourDetailInternalImage');

        let selectedTour = null;

        function openTourDetail(tourId) {
            const found = toursAtData.find((tour) => String(tour.id) === String(tourId));
            if (!found || found.estado !== 'activo') {
                return;
            }

            selectedTour = found;
            titleEl.textContent = found.titulo;
            metaEl.textContent = `${found.ubicacion} · ${found.duracion} · Vendedor #${found.vendedor_id}`;
            estadoEl.textContent = found.estado;
            estadoEl.classList.remove('activo', 'inactivo');
            estadoEl.classList.add(found.estado);
            destacadoEl.hidden = !found.destacado;

            descripcionEl.textContent = found.descripcion;
            incluyeEl.textContent = found.incluye;

            noIncluyeWrapEl.hidden = !found.no_incluye;
            noIncluyeEl.textContent = found.no_incluye || '';

            itinerarioWrapEl.hidden = !found.itinerario;
            itinerarioEl.textContent = found.itinerario || '';

            const internalImage = Array.isArray(found.galeria) && found.galeria.length > 0
                ? found.galeria[0]
                : found.imagen_principal;
            internalImageEl.src = internalImage;
            internalImageEl.alt = `${found.titulo} imagen interna`;

            galleryEl.innerHTML = '';
            (found.galeria || []).forEach((src, index) => {
                const img = document.createElement('img');
                img.src = src;
                img.alt = `${found.titulo} galería ${index + 1}`;
                img.loading = 'lazy';
                galleryEl.appendChild(img);
            });

            priceEl.textContent = found.precio;

            modal.hidden = false;
            document.body.classList.add('tour-modal-open');
        }

        function closeTourDetail() {
            modal.hidden = true;
            document.body.classList.remove('tour-modal-open');
            selectedTour = null;
        }

        document.querySelectorAll('[data-open-tour]').forEach((button) => {
            button.addEventListener('click', () => {
                openTourDetail(button.getAttribute('data-open-tour'));
            });
        });

        document.querySelectorAll('[data-close-modal]').forEach((button) => {
            button.addEventListener('click', closeTourDetail);
        });

        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape' && !modal.hidden) {
                closeTourDetail();
            }
        });

        reserveBtn.addEventListener('click', () => {
            if (!selectedTour) {
                return;
            }

            const message = `Hola, quiero reservar ${selectedTour.titulo} (${selectedTour.duracion}) por ${selectedTour.precio}.`;
            const whatsappUrl = `https://wa.me/${whatsappDigits}?text=${encodeURIComponent(message)}`;
            window.open(whatsappUrl, '_blank', 'noopener,noreferrer');
        });
    </script>

</AppLayout>
