---
import AppLayout from "../layouts/AppLayout.astro";

const title = "Centro de Ayuda - ATRAVEL";
---

<AppLayout title={title}>
<!-- Hero Section -->
    <section class="ayuda-hero">
        <div class="ayuda-hero-content">
            <h1>Centro de Ayuda</h1>
            <p>Encuentra respuestas a tus preguntas y soluciona problemas rápidamente</p>
        </div>
    </section>

    <!-- Main Content -->
    <main class="ayuda-main">
        <!-- Search Section -->
        <section class="search-section">
            <div class="search-container">
                <h2>¿Cómo podemos ayudarte?</h2>
                <p>Busca una respuesta o explora nuestras categorías</p>
                <div class="search-input-wrapper">
                    <input 
                        type="text" 
                        id="faqSearch" 
                        placeholder="Busca por palabra clave (reserva, pago, cancelación...)"
                    >
                    <i class="fas fa-search"></i>
                </div>
            </div>
        </section>

        <!-- Quick Links Cards -->
        <section class="categories-section">
            <h3>Categorías Principales</h3>
            <div class="categories-grid">
                <div class="category-card" onclick="scrollToSection('reservas')">
                    <i class="fas fa-ticket-alt"></i>
                    <h3>Reservas</h3>
                    <p>Cómo hacer y gestionar reservas</p>
                </div>

                <div class="category-card" onclick="scrollToSection('pagos')">
                    <i class="fas fa-credit-card"></i>
                    <h3>Pagos</h3>
                    <p>Métodos de pago y facturación</p>
                </div>

                <div class="category-card" onclick="scrollToSection('cancelaciones')">
                    <i class="fas fa-times-circle"></i>
                    <h3>Cancelaciones</h3>
                    <p>Políticas de cancelación</p>
                </div>
            </div>
        </section>

        <!-- FAQs Container -->
        <section class="faq-sections">

        <!-- Reservas Section -->
        <section class="faq-section" id="reservas">
            <h2 class="faq-section-title">
                <i class="fas fa-ticket-alt"></i>Reservas
            </h2>
            <div class="faq-items">
                <details>
                    <summary>¿Cómo realizo una reserva?</summary>
                    <div class="faq-content">
                        <ol>
                            <li>Navega a la página del destino o tour que deseas</li>
                            <li>Selecciona las fechas de tu viaje</li>
                            <li>Elige el número de viajeros</li>
                            <li>Haz clic en "Reservar" o "Agregar al Carrito"</li>
                            <li>Completa tus datos de contacto</li>
                            <li>Revisa el resumen de tu reserva</li>
                            <li>Procede al pago</li>
                            <li>¡Recibirás confirmación por email!</li>
                        </ol>
                    </div>
                </details>

                <details>
                    <summary>¿Necesito crear una cuenta para reservar?</summary>
                    <div class="faq-content">
                        <p>No. Puedes reservar directamente con tus datos de contacto y recibirás toda la información por email.</p>
                    </div>
                </details>

                <details>
                    <summary>¿Puedo cambiar mis fechas de viaje después de reservar?</summary>
                    <div class="faq-content">
                        <p>Sí, puedes cambiar tus fechas según estas condiciones:</p>
                        <ul>
                            <li><strong>Hasta 7 días antes:</strong> Sin costo adicional</li>
                            <li><strong>Entre 3-7 días:</strong> 10% del costo total</li>
                            <li><strong>Menos de 3 días:</strong> No se permite cambio, solo cancelación</li>
                        </ul>
                        <div class="highlight-box warning">
                            <i class="fas fa-info-circle"></i>
                            Contactanos al chat para realizar cambios en tu reserva.
                        </div>
                    </div>
                </details>

                <details>
                    <summary>¿Qué documentos necesito para viajar?</summary>
                    <div class="faq-content">
                        <div>
                            <div>
                                <h4>Viajes nacionales:</h4>
                                <ul>
                                    <li>DNI o Pasaporte vigente</li>
                                    <li>Boletos de transporte (proporcionados por ATRAVEL)</li>
                                </ul>
                            </div>
                            <div>
                                <h4>Viajes internacionales:</h4>
                                <ul>
                                    <li>Pasaporte vigente (mínimo 6 meses)</li>
                                    <li>Visa si es requerida por el país</li>
                                    <li>Certificados de vacunación (si aplica)</li>
                                    <li>Seguro de viaje recomendado</li>
                                </ul>
                            </div>
                        </div>
                        <div class="highlight-box info">
                            <i class="fas fa-lightbulb"></i>
                            Verifica los requisitos específicos de cada destino antes de tu viaje.
                        </div>
                    </div>
                </details>

                <details>
                    <summary>¿Cuál es la política de menores de edad?</summary>
                    <div class="faq-content">
                        <ul>
                            <li>Menores de 18 años deben viajar con un adulto responsable</li>
                            <li>Se requiere autorización escrita de ambos padres/tutores</li>
                            <li>Descuentos especiales para menores (ver página de tarifas)</li>
                            <li>Disponemos de servicios de acompañamiento especial</li>
                        </ul>
                    </div>
                </details>
            </div>
        </section>

        <!-- Pagos Section -->
        <section class="faq-section" id="pagos">
            <h2 class="faq-section-title">
                <i class="fas fa-credit-card"></i>Pagos y Facturación
            </h2>
            <div class="faq-items">
                <details>
                    <summary>¿Qué métodos de pago aceptan?</summary>
                    <div class="faq-content">
                        <div>
                            <div>
                                <i class="fas fa-credit-card text-purple-600 text-2xl"></i>
                                <span>Tarjeta de Crédito/Débito</span>
                            </div>
                            <div>
                                <i class="fas fa-money-bill text-green-600 text-2xl"></i>
                                <span>Transferencia Bancaria</span>
                            </div>
                            <div>
                                <i class="fas fa-wallet text-blue-600 text-2xl"></i>
                                <span>Billetera Digital</span>
                            </div>
                            <div>
                                <i class="fas fa-university text-indigo-600 text-2xl"></i>
                                <span>Efectivo en Oficina</span>
                            </div>
                        </div>
                        <p>Aceptamos Visa, Mastercard, American Express y billeteras digitales locales.</p>
                    </div>
                </details>

                <details>
                    <summary>¿Es seguro dar mis datos de pago?</summary>
                    <div class="faq-content">
                        <p>Absolutamente sí. Contamos con:</p>
                        <ul>
                            <li>Certificado SSL de 256-bit encryption</li>
                            <li>Cumplimiento con estándares PCI DSS</li>
                            <li>Procesadores de pago certificados internacionalmente</li>
                            <li>Protección contra fraude 24/7</li>
                            <li>Nunca almacenamos datos completos de tarjetas</li>
                        </ul>
                    </div>
                </details>

                <details>
                    <summary>¿Cuándo se cobra mi reserva?</summary>
                    <div class="faq-content">
                        <ul>
                            <li>Se cobra al momento de confirmar la reserva</li>
                            <li>Se envía comprobante de pago a tu email</li>
                            <li>No hay cargos ocultos adicionales</li>
                            <li>En algunos tours, puede aplicarse política de depósito y saldo</li>
                        </ul>
                    </div>
                </details>

                <details>
                    <summary>¿Cómo puedo obtener mi factura?</summary>
                    <div class="faq-content">
                        <ol>
                            <li>Escríbenos por el formulario de soporte</li>
                            <li>Indica tu código de reserva</li>
                            <li>Comparte tu razón social o datos de facturación</li>
                            <li>Nuestro equipo te enviará la factura por email</li>
                        </ol>
                    </div>
                </details>

                <details>
                    <summary>¿Hay descuentos disponibles?</summary>
                    <div class="faq-content">
                        <p>Ofrecemos varias opciones de descuento:</p>
                        <ul>
                            <li><strong>Grupos (4+ personas):</strong> 5-15% descuento</li>
                            <li><strong>Reserva anticipada:</strong> 10% descuento si reservas 60 días antes</li>
                            <li><strong>Cliente frecuente:</strong> 8% en siguientes reservas</li>
                            <li><strong>Estudiantes/Seniors:</strong> Descuentos especiales con validación</li>
                            <li><strong>Ofertas estacionales:</strong> Revisa nuestra sección de "Ofertas"</li>
                        </ul>
                    </div>
                </details>
            </div>
        </section>

        <!-- Cancelaciones Section -->
        <section class="faq-section" id="cancelaciones">
            <h2 class="faq-section-title">
                <i class="fas fa-times-circle"></i>Cancelaciones y Reembolsos
            </h2>
            <div class="faq-items">
                <details>
                    <summary>¿Cuál es la política de cancelación?</summary>
                    <div class="faq-content">
                        <div>
                            <div class="highlight-box success">
                                <strong>Hasta 30 días antes:</strong> Reembolso 100%
                            </div>
                            <div class="highlight-box warning">
                                <strong>15 a 29 días antes:</strong> Reembolso 50% + gastos administrativos
                            </div>
                            <div class="highlight-box error">
                                <strong>7 a 14 días antes:</strong> Reembolso 25% + gastos administrativos
                            </div>
                            <div class="highlight-box error">
                                <strong>Menos de 7 días:</strong> No se autoriza cancelación, solo canje
                            </div>
                        </div>
                    </div>
                </details>

                <details>
                    <summary>¿Cuánto tiempo tarda el reembolso?</summary>
                    <div class="faq-content">
                        <ul>
                            <li>Procesamiento: 3-5 días hábiles</li>
                            <li>Transferencia bancaria: 2-5 días adicionales</li>
                            <li>Tarjeta de crédito: 5-10 días adicionales</li>
                            <li>Billetera digital: Inmediato o hasta 1 día</li>
                        </ul>
                        <div class="highlight-box blue">
                            Recibirás notificación por email cuando se inicie el reembolso.
                        </div>
                    </div>
                </details>

                <details>
                    <summary>¿Qué razones puedo dar para cancelar?</summary>
                    <div class="faq-content">
                        <p>Puedes cancelar por cualquier razón, pero según la causa:</p>
                        <ul>
                            <li><strong>Personal:</strong> Aplican políticas estándar</li>
                            <li><strong>Médica:</strong> Pueden aplicar políticas especiales con justificante</li>
                            <li><strong>Cambios de clima extremo:</strong> Podría haber reembolso 100%</li>
                            <li><strong>Cancelación por ATRAVEL:</strong> Reembolso 100% o cambio de fecha</li>
                        </ul>
                    </div>
                </details>

                <details>
                    <summary>¿Cómo cancelo mi reserva?</summary>
                    <div class="faq-content">
                        <ol>
                            <li>Contáctanos por chat, teléfono o correo</li>
                            <li>Comparte tu código de reserva</li>
                            <li>Te indicaremos condiciones y monto de reembolso</li>
                            <li>Confirmaremos la solicitud de cancelación por email</li>
                        </ol>
                    </div>
                </details>
            </div>
        </section>

        </section>

        <!-- Support Section -->
        <section class="support-section">
            <h2>¿Aún necesitas ayuda?</h2>
            <p>Nuestro equipo de soporte está disponible para asistirte de múltiples formas</p>
            
            <div class="support-grid">
                <div class="support-card">
                    <i class="fas fa-comments"></i>
                    <h3>Chat en Vivo</h3>
                    <p>Disponible 24/7</p>
                    <button onclick="openSupportModal('chat')">
                        Iniciar Chat
                    </button>
                </div>

                <div class="support-card">
                    <i class="fas fa-phone"></i>
                    <h3>Teléfono</h3>
                    <p>Lunes a Viernes 9AM-6PM</p>
                    <button onclick="openSupportModal('phone')">
                        Llamar (01) 234-5678
                    </button>
                </div>

                <div class="support-card">
                    <i class="fas fa-envelope"></i>
                    <h3>Email</h3>
                    <p>Respuesta en 24 horas</p>
                    <button onclick="openSupportModal('email')">
                        Enviar Correo
                    </button>
                </div>

                <div class="support-card">
                    <i class="fas fa-map-marker-alt"></i>
                    <h3>Oficinas</h3>
                    <p>Visítanos en Lima</p>
                    <button onclick="openSupportModal('location')">
                        Ver Ubicación
                    </button>
                </div>
            </div>
        </section>

        <!-- System Status -->
        <section class="status-section">
            <h2>Estado del Sistema</h2>
            <div class="status-items">
                <div class="status-item">
                    <div class="status-info">
                        <i class="fas fa-check-circle"></i>
                        <span>API de Reservas</span>
                    </div>
                    <span class="status-badge status-operational">Operativo</span>
                </div>
                <div class="status-item">
                    <div class="status-info">
                        <i class="fas fa-check-circle"></i>
                        <span>Sistema de Pagos</span>
                    </div>
                    <span class="status-badge status-operational">Operativo</span>
                </div>
                <div class="status-item">
                    <div class="status-info">
                        <i class="fas fa-check-circle"></i>
                        <span>Email de Confirmación</span>
                    </div>
                    <span class="status-badge status-operational">Operativo</span>
                </div>
            </div>
            <p class="status-last-update">Última actualización: hace 5 minutos - <a href="#">Ver historial</a></p>
        </section>
    </main>

    <!-- Support Modal -->
    <div id="supportModal" class="modal-overlay" onclick="if(event.target === this) closeSupportModal()">
        <div class="modal-content">
            <button class="modal-close" onclick="closeSupportModal()">
                <i class="fas fa-times"></i>
            </button>
            <h2 class="modal-title">Contacta con Nosotros</h2>
            
            <form class="modal-form" id="supportForm">
                <div class="form-group">
                    <label>Tu Nombre</label>
                    <input type="text" name="name" required placeholder="ej: Juan Pérez">
                </div>

                <div class="form-group">
                    <label>Email</label>
                    <input type="email" name="email" required placeholder="tu@email.com">
                </div>

                <div class="form-group">
                    <label>Teléfono (Opcional)</label>
                    <input type="tel" name="phone" placeholder="+51 999 999 999">
                </div>

                <div class="form-group">
                    <label>Asunto</label>
                    <select name="subject" required>
                        <option value="">Selecciona un asunto...</option>
                        <option value="reserva">Problema con Reserva</option>
                        <option value="pago">Problema con Pago</option>
                        <option value="cancelacion">Solicitud de Cancelación</option>
                        <option value="sugerencia">Sugerencia o Comentario</option>
                        <option value="otro">Otro</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Mensaje</label>
                    <textarea name="message" required placeholder="Cuéntanos cómo podemos ayudarte..."></textarea>
                </div>

                <button type="submit" class="btn-modal-submit">Enviar Mensaje</button>
            </form>
        </div>
    </div>

    <script>
        // FAQ Search
        document.getElementById('faqSearch').addEventListener('input', function(e) {
            const searchTerm = e.target.value.toLowerCase();
            const details = document.querySelectorAll('details');
            
            details.forEach(detail => {
                const text = detail.textContent.toLowerCase();
                detail.style.display = text.includes(searchTerm) ? 'block' : 'none';
            });
        });

        // Scroll to section
        function scrollToSection(sectionId) {
            const element = document.getElementById(sectionId);
            if (element) {
                element.scrollIntoView({ behavior: 'smooth' });
            }
        }

        // Support Modal
        function openSupportModal(type) {
            document.getElementById('supportModal').style.display = 'flex';

            if (type === 'phone') {
                alert('Teléfono: +51 (1) 234-5678\nLunes a Viernes: 9AM - 6PM');
            } else if (type === 'location') {
                alert('ATRAVEL - Oficina Principal\nAv. Larco 1200, Miraflores, Lima 18\nPeru');
            }
        }

        function closeSupportModal() {
            document.getElementById('supportModal').style.display = 'none';
        }

        // Close modal when clicking outside
        document.getElementById('supportModal').addEventListener('click', function(e) {
            if (e.target === this) closeSupportModal();
        });

        async function postSupportRequest(data) {
            const response = await fetch('/api/support', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(data)
            });

            const result = await response.json();
            if (!response.ok) {
                throw new Error(result.message || 'No se pudo enviar el mensaje.');
            }

            return result;
        }

        // Form submission
        document.getElementById('supportForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            try {
                const data = Object.fromEntries(new FormData(this).entries());
                const result = await postSupportRequest(data);
                showNotification(result.message, 'success');
                closeSupportModal();
                this.reset();
            } catch (error) {
                showNotification(error.message, 'error');
            }
        });
    </script>
</AppLayout>

