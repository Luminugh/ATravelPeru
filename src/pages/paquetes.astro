---
import AppLayout from "../layouts/AppLayout.astro";
import { getCatalogByService } from "../lib/catalog";

const title = "Paquetes - ATRAVEL";
const { items: paquetesData, error: paquetesError, source } = await getCatalogByService("paquetes");
const ubicaciones = [...new Set(paquetesData.map((item) => item.ubicacion).filter(Boolean))];
---

<AppLayout title={title}>
  <section class="hero-section hero-secondary">
    <div class="hero-background">
      <video autoplay muted loop class="hero-video">
        <source src="/assets/videos/Video1.mp4" type="video/mp4" />
        Tu navegador no soporta videos.
      </video>
    </div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <div class="hero-badge">Todo en un solo paquete</div>
      <h2 class="hero-title">Paquetes desde base de datos</h2>
      <p class="hero-subtitle">Los paquetes se renderizan dinamicamente desde Supabase.</p>
      <div class="hero-actions">
        <a class="btn-hero-primary" href="#paquetes-content">Ver paquetes</a>
      </div>
    </div>
  </section>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <section class="paquetes-filters mb-12">
      <h2 class="text-2xl font-bold mb-8 text-gray-900">Filtrar por destino</h2>
      <div class="filters-container">
        <div class="filter-group">
          <label class="filter-label">Destino</label>
          <select class="filter-select">
            <option>Todos</option>
            {ubicaciones.map((ubicacion) => <option>{ubicacion}</option>)}
          </select>
        </div>
        <button class="btn-filter-search" type="button">Filtrar</button>
      </div>
    </section>

    <section id="paquetes-content" class="tours-section">
      <h2 class="section-title mb-12">Paquetes del catalogo</h2>

      {paquetesData.length === 0 && (
        <div class="rounded-xl border border-red-200 bg-red-50 p-4 text-red-900 mb-6">
          <p class="font-bold">No hay paquetes para mostrar.</p>
          <p>Fuente: {source}</p>
          {paquetesError && <p>Error: {paquetesError}</p>}
          <p>Ejecuta la migracion y carga datos en Supabase para servicio = paquetes.</p>
        </div>
      )}

      <div class="tours-grid">
        {paquetesData.map((item) => (
          <article class="tour-summary-card">
            <div class="summary-image-wrap">
              <img src={item.imagen_principal} alt={item.titulo} class="summary-image" loading="lazy" />
              <div class="summary-badges">
                {item.destacado && <span class="summary-badge destacado">Destacado</span>}
                <span class={`summary-badge estado ${item.estado}`}>{item.estado}</span>
              </div>
            </div>
            <div class="summary-content">
              <h3 class="summary-title">{item.titulo}</h3>
              <p class="summary-meta"><i class="fas fa-calendar-days"></i> {item.duracion} · <i class="fas fa-map-marker-alt"></i> {item.ubicacion}</p>
              <p class="summary-description">{item.descripcion}</p>
              <div class="summary-footer">
                <span class="summary-price">${item.precio}</span>
                <button class="btn-summary-open" type="button" disabled={item.estado !== "activo"} onclick="showNotification('Solicitud de reserva enviada', 'success')">
                  {item.estado === "activo" ? "Reservar" : "No disponible"}
                </button>
              </div>
            </div>
          </article>
        ))}
        ))}
      </div>
    </section>
  </main>
</AppLayout>
