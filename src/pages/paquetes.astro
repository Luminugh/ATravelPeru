---
import AppLayout from "../layouts/AppLayout.astro";

const title = "Paquetes - ATRAVEL";
---

<AppLayout title={title}>
<!-- Hero Section Paquetes -->
    <section class="hero-section hero-secondary">
        <div class="hero-background">
            <video autoplay muted loop class="hero-video">
                <source src="/assets/videos/Video1.mp4" type="video/mp4">
                Tu navegador no soporta videos.
            </video>
        </div>
        <div class="hero-overlay"></div>
        <div class="hero-content">
            <div class="hero-badge">Todo incluido para ti</div>
            <h2 class="hero-title">Paquetes Turísticos Completos</h2>
            <p class="hero-subtitle">Viaja sin preocupaciones con nuestros paquetes todo incluido: vuelos, hoteles, tours y comidas</p>
            
            <div class="hero-features">
                <div class="hero-feature-item">
                    <i class="fas fa-suitcase-rolling feature-icon"></i>
                    <span class="feature-text">20+ Paquetes</span>
                </div>
                <div class="hero-feature-item">
                    <i class="fas fa-utensils feature-icon"></i>
                    <span class="feature-text">Todo Incluido</span>
                </div>
                <div class="hero-feature-item">
                    <i class="fas fa-heart feature-icon"></i>
                    <span class="feature-text">Experiencias Únicas</span>
                </div>
            </div>

            <div class="hero-actions">
                <button class="btn-hero-primary" onclick="document.querySelector('.paquetes-filters').scrollIntoView({behavior: 'smooth'})">Explorar Paquetes</button>
                <button class="btn-hero-secondary">Ofertas Especiales</button>
            </div>
        </div>
    </section>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        
        <!-- Filter Section -->
        <section class="paquetes-filters mb-12">
            <h2 class="text-2xl font-bold mb-8 text-gray-900">Encuentra tu Paquete Ideal</h2>
            <div class="filters-container">
                <div class="filter-group">
                    <label class="filter-label">Destino</label>
                    <select class="filter-select">
                        <option>Todos los destinos</option>
                        <option>Cusco</option>
                        <option>Machu Picchu</option>
                        <option>Valle Sagrado</option>
                        <option>Selva Peruana</option>
                        <option>Lima</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label class="filter-label">Duración</label>
                    <select class="filter-select">
                        <option>Cualquier duración</option>
                        <option>3 días</option>
                        <option>4-5 días</option>
                        <option>6-7 días</option>
                        <option>8+ días</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label class="filter-label">Precio</label>
                    <select class="filter-select">
                        <option>Cualquier precio</option>
                        <option>Hasta S/ 1,000</option>
                        <option>S/ 1,000 - S/ 2,000</option>
                        <option>S/ 2,000 - S/ 3,500</option>
                        <option>Más de S/ 3,500</option>
                    </select>
                </div>
                <button class="btn-filter-search">Filtrar</button>
            </div>
        </section>

        <!-- Packages Grid -->
        <section class="tours-section">
            <h2 class="section-title mb-12">Nuestros Paquetes Destacados</h2>
            <div class="tours-grid">
                
                <!-- Package 1 -->
                <div class="tour-card">
                    <div class="tour-image">
                        <img src="https://via.placeholder.com/400x250/FF6B6B/FFFFFF?text=Machu+Picchu" alt="Machu Picchu Clásico">
                        <div class="tour-badge tour-badge-popular">Popular</div>
                    </div>
                    <div class="tour-content">
                        <h3 class="tour-title">Machu Picchu Clásico</h3>
                        <div class="tour-meta">
                            <span class="tour-duration"><i class="fas fa-calendar-days"></i> 4 Días</span>
                            <span class="tour-difficulty difficulty-moderado">Todo Incluido</span>
                        </div>
                        <p class="tour-description">Vive la experiencia completa de Machu Picchu con tren de lujo, hotel 4 estrellas y guía especializado en arqueología inca.</p>
                        <div class="tour-features">
                            <span class="feature-tag">Tren de lujo</span>
                            <span class="feature-tag">Hotel premium</span>
                            <span class="feature-tag">Guía bilingüe</span>
                        </div>
                        <div class="tour-footer">
                            <div class="tour-price">
                                <span class="price-label">Desde</span>
                                <span class="price-value">S/ 1,450</span>
                            </div>
                            <button class="btn-tour-reserve" onclick="showNotification('Solicitud de reserva enviada', 'success')">Reservar</button>
                        </div>
                    </div>
                </div>

                <!-- Package 2 -->
                <div class="tour-card">
                    <div class="tour-image">
                        <img src="https://via.placeholder.com/400x250/4ECDC4/FFFFFF?text=Valle+Sagrado" alt="Valle Sagrado Express">
                        <div class="tour-badge tour-badge-new">Nuevo</div>
                    </div>
                    <div class="tour-content">
                        <h3 class="tour-title">Valle Sagrado Express</h3>
                        <div class="tour-meta">
                            <span class="tour-duration"><i class="fas fa-calendar-days"></i> 2 Días</span>
                            <span class="tour-difficulty difficulty-facil">Todo Incluido</span>
                        </div>
                        <p class="tour-description">Recorrido rápido pero completo del Valle Sagrado: Ollantaytambo, Pisac, Chinchero con visita a mercados tradicionales andinos.</p>
                        <div class="tour-features">
                            <span class="feature-tag">Mercados locales</span>
                            <span class="feature-tag">Hotel boutique</span>
                            <span class="feature-tag">Transporte privado</span>
                        </div>
                        <div class="tour-footer">
                            <div class="tour-price">
                                <span class="price-label">Desde</span>
                                <span class="price-value">S/ 620</span>
                            </div>
                            <button class="btn-tour-reserve" onclick="showNotification('Solicitud de reserva enviada', 'success')">Reservar</button>
                        </div>
                    </div>
                </div>

                <!-- Package 3 -->
                <div class="tour-card">
                    <div class="tour-image">
                        <img src="https://via.placeholder.com/400x250/95E1D3/FFFFFF?text=Selva+Peruana" alt="Aventura en la Selva">
                    </div>
                    <div class="tour-content">
                        <h3 class="tour-title">Aventura en la Selva</h3>
                        <div class="tour-meta">
                            <span class="tour-duration"><i class="fas fa-calendar-days"></i> 3 Días</span>
                            <span class="tour-difficulty difficulty-dificil">Extremo</span>
                        </div>
                        <p class="tour-description">Inmersión total en la Amazonía: lodge ecológico, excursiones selva, avistamiento de fauna y experiencias con comunidades nativas.</p>
                        <div class="tour-features">
                            <span class="feature-tag">Lodge eco-amigable</span>
                            <span class="feature-tag">Guía naturalista</span>
                            <span class="feature-tag">All-inclusive</span>
                        </div>
                        <div class="tour-footer">
                            <div class="tour-price">
                                <span class="price-label">Desde</span>
                                <span class="price-value">S/ 980</span>
                            </div>
                            <button class="btn-tour-reserve" onclick="showNotification('Solicitud de reserva enviada', 'success')">Reservar</button>
                        </div>
                    </div>
                </div>

                <!-- Package 4 -->
                <div class="tour-card">
                    <div class="tour-image">
                        <img src="https://via.placeholder.com/400x250/F38181/FFFFFF?text=Cusco+Completo" alt="Cusco Completo">
                        <div class="tour-badge tour-badge-top">Top Rating</div>
                    </div>
                    <div class="tour-content">
                        <h3 class="tour-title">Cusco Completo 5 Días</h3>
                        <div class="tour-meta">
                            <span class="tour-duration"><i class="fas fa-calendar-days"></i> 5 Días</span>
                            <span class="tour-difficulty difficulty-facil">Premium</span>
                        </div>
                        <p class="tour-description">Descubre la capital inca: Sacsayhuamán, Qoricancha, barrios coloniales, museos, gastronomía 5 estrellas y vida nocturna.</p>
                        <div class="tour-features">
                            <span class="feature-tag">Restaurantes gourmet</span>
                            <span class="feature-tag">Museos premium</span>
                            <span class="feature-tag">Tours privados</span>
                        </div>
                        <div class="tour-footer">
                            <div class="tour-price">
                                <span class="price-label">Desde</span>
                                <span class="price-value">S/ 1,680</span>
                            </div>
                            <button class="btn-tour-reserve" onclick="showNotification('Solicitud de reserva enviada', 'success')">Reservar</button>
                        </div>
                    </div>
                </div>

                <!-- Package 5 -->
                <div class="tour-card">
                    <div class="tour-image">
                        <img src="https://via.placeholder.com/400x250/AA96DA/FFFFFF?text=Lima+Cultura" alt="Lima Gastronómica y Cultural">
                    </div>
                    <div class="tour-content">
                        <h3 class="tour-title">Lima Gastronómica</h3>
                        <div class="tour-meta">
                            <span class="tour-duration"><i class="fas fa-calendar-days"></i> 3 Días</span>
                            <span class="tour-difficulty difficulty-facil">Lujo</span>
                        </div>
                        <p class="tour-description">Capital gastronómica mundial: restaurantes Michelin, clases de cocina, museos, miradores y experiencias culinarias exclusivas.</p>
                        <div class="tour-features">
                            <span class="feature-tag">Chef participante</span>
                            <span class="feature-tag">Restaurantes top</span>
                            <span class="feature-tag">Clase de cocina</span>
                        </div>
                        <div class="tour-footer">
                            <div class="tour-price">
                                <span class="price-label">Desde</span>
                                <span class="price-value">S/ 1,290</span>
                            </div>
                            <button class="btn-tour-reserve" onclick="showNotification('Solicitud de reserva enviada', 'success')">Reservar</button>
                        </div>
                    </div>
                </div>

                <!-- Package 6 -->
                <div class="tour-card">
                    <div class="tour-image">
                        <img src="https://via.placeholder.com/400x250/FCBAD3/FFFFFF?text=Titicaca+Completo" alt="Titicaca Completo">
                    </div>
                    <div class="tour-content">
                        <h3 class="tour-title">Lago Titicaca Completo</h3>
                        <div class="tour-meta">
                            <span class="tour-duration"><i class="fas fa-calendar-days"></i> 3 Días</span>
                            <span class="tour-difficulty difficulty-moderado">Aventura</span>
                        </div>
                        <p class="tour-description">Islas flotantes, Isla de Taquile, pueblos y tradiciones ancestrales. Hotel frente al lago con vistas espectaculares.</p>
                        <div class="tour-features">
                            <span class="feature-tag">Islas flotantes</span>
                            <span class="feature-tag">Casa local</span>
                            <span class="feature-tag">Artesanías locales</span>
                        </div>
                        <div class="tour-footer">
                            <div class="tour-price">
                                <span class="price-label">Desde</span>
                                <span class="price-value">S/ 850</span>
                            </div>
                            <button class="btn-tour-reserve" onclick="showNotification('Solicitud de reserva enviada', 'success')">Reservar</button>
                        </div>
                    </div>
                </div>

            </div>
        </section>

        <!-- Why Choose Paquetes Section -->
        <section class="why-choose-section mt-20">
            <h2 class="section-title mb-12">¿Por qué elegir nuestros Paquetes?</h2>
            <div class="why-choose-grid">
                <div class="why-choose-card">
                    <i class="fas fa-check-circle why-choose-icon"></i>
                    <h3 class="why-choose-title">Todo Incluido</h3>
                    <p class="why-choose-text">Vuelos, hoteles, tours y comidas: no hay sorpresas aumentando el costo final de tu viaje.</p>
                </div>
                <div class="why-choose-card">
                    <i class="fas fa-users why-choose-icon"></i>
                    <h3 class="why-choose-title">Grupos Reducidos</h3>
                    <p class="why-choose-text">Máximo 15 personas por grupo para una experiencia más personalizada y memorable.</p>
                </div>
                <div class="why-choose-card">
                    <i class="fas fa-calendar-check why-choose-icon"></i>
                    <h3 class="why-choose-title">Salidas Programadas</h3>
                    <p class="why-choose-text">Múltiples fechas de salida mensuales para que encuentres la que mejor se adapte a tu agenda.</p>
                </div>
                <div class="why-choose-card">
                    <i class="fas fa-handshake why-choose-icon"></i>
                    <h3 class="why-choose-title">Operadores Certificados</h3>
                    <p class="why-choose-text">Todos nuestros operadores tienen certificación turística y años de experiencia garantizada.</p>
                </div>
                <div class="why-choose-card">
                    <i class="fas fa-shield-alt why-choose-icon"></i>
                    <h3 class="why-choose-title">Seguro de Viaje</h3>
                    <p class="why-choose-text">Cada paquete incluye seguro de viaje completo: médico, cancelación y cobertura general.</p>
                </div>
                <div class="why-choose-card">
                    <i class="fas fa-star why-choose-icon"></i>
                    <h3 class="why-choose-title">Experiencias Exclusivas</h3>
                    <p class="why-choose-text">Acceso a lugares privados, cenas especiales y actividades no disponibles al público general.</p>
                </div>
            </div>
        </section>

        <!-- CTA Section -->
        <section class="cta-section mt-20 bg-gradient-to-r from-green-600 to-emerald-500 rounded-2xl px-8 py-12 text-white">
            <div class="max-w-2xl mx-auto text-center">
                <h2 class="text-3xl font-bold mb-4">Reserva tu Paquete Perfecto</h2>
                <p class="text-lg mb-8 text-green-100">Descubre el Perú con tranquilidad: todo está incluido en nuestros paquetes</p>
                <button class="btn-cta-primary" onclick="showNotification('Te contactaremos pronto', 'success')">Reservar Paquete Ahora</button>
            </div>
        </section>
    </main>
</AppLayout>


