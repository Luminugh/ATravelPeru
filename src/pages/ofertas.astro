---
import AppLayout from "../layouts/AppLayout.astro";

const title = "Ofertas - ATRAVEL";
---

<AppLayout title={title}>
<!-- Hero Section Ofertas -->
    <section class="hero-section">
        <div class="hero-background">
            <video autoplay muted loop class="hero-video">
                <source src="/assets/videos/Video1.mp4" type="video/mp4">
                Tu navegador no soporta videos.
            </video>
        </div>
        <div class="hero-overlay"></div>
        <div class="hero-content">
            <div class="hero-badge">Descuentos increíbles</div>
            <h2 class="hero-title">Ofertas Especiales Exclusivas</h2>
            <p class="hero-subtitle">Aprovecha nuestras promociones limitadas con descuentos de hasta 50% en vuelos, hoteles y paquetes completos</p>
            
            <div class="hero-features">
                <div class="hero-feature-item">
                    <i class="fas fa-percentage feature-icon"></i>
                    <span class="feature-text">Hasta 50% OFF</span>
                </div>
                <div class="hero-feature-item">
                    <i class="fas fa-hourglass-end feature-icon"></i>
                    <span class="feature-text">Tiempo Limitado</span>
                </div>
                <div class="hero-feature-item">
                    <i class="fas fa-bolt feature-icon"></i>
                    <span class="feature-text">Oferta Flash</span>
                </div>
            </div>

            <div class="hero-actions">
                <button class="btn-hero-primary" onclick="document.querySelector('.ofertas-filters').scrollIntoView({behavior: 'smooth'})">Ver Ofertas</button>
                <button class="btn-hero-secondary">Suscribirse a Alertas</button>
            </div>
        </div>
    </section>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        
        <!-- Filter Section -->
        <section class="ofertas-filters mb-12">
            <h2 class="text-2xl font-bold mb-8 text-gray-900">Filtra Nuestras Ofertas</h2>
            <div class="filters-container">
                <div class="filter-group">
                    <label class="filter-label">Tipo</label>
                    <select class="filter-select">
                        <option>Todas las ofertas</option>
                        <option>Vuelos</option>
                        <option>Hoteles</option>
                        <option>Paquetes</option>
                        <option>Tours</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label class="filter-label">Descuento Mínimo</label>
                    <select class="filter-select">
                        <option>Cualquier descuento</option>
                        <option>10% o más</option>
                        <option>20% o más</option>
                        <option>30% o más</option>
                        <option>40% o más</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label class="filter-label">Vigencia</label>
                    <select class="filter-select">
                        <option>Vigentes</option>
                        <option>Esta semana</option>
                        <option>Este mes</option>
                        <option>Próximo mes</option>
                    </select>
                </div>
                <button class="btn-filter-search">Filtrar</button>
            </div>
        </section>

        <!-- Offers Grid Section -->
        <section class="tours-section">
            <h2 class="section-title mb-12">Mejores Ofertas del Momento</h2>
            <div class="tours-grid">
                
                <!-- Offer 1 -->
                <div class="tour-card">
                    <div class="tour-image">
                        <img src="https://via.placeholder.com/400x250/FF6B6B/FFFFFF?text=Machu+Picchu" alt="Oferta Machu Picchu">
                        <div class="tour-badge tour-badge-popular">-35%</div>
                    </div>
                    <div class="tour-content">
                        <h3 class="tour-title">Machu Picchu Experiencia</h3>
                        <div class="tour-meta">
                            <span class="tour-duration"><i class="fas fa-fire"></i> Flash Sale</span>
                            <span class="tour-difficulty difficulty-moderado">Paquete</span>
                        </div>
                        <p class="tour-description">Vive la maravilla del mundo con todo incluido. Hotel 5 estrellas, tren de lujo, guía premium y todas las comidas.</p>
                        <div class="tour-features">
                            <span class="feature-tag">Válido abril-junio</span>
                            <span class="feature-tag">2 personas mín</span>
                            <span class="feature-tag">Cancelación gratis</span>
                        </div>
                        <div class="tour-footer">
                            <div class="tour-price">
                                <span class="price-label">Desde</span>
                                <span class="price-value">S/ 1,430</span>
                            </div>
                            <button class="btn-tour-reserve" onclick="showNotification('Solicitud enviada', 'success')">Aprovechar</button>
                        </div>
                    </div>
                </div>

                <!-- Offer 2 -->
                <div class="tour-card">
                    <div class="tour-image">
                        <img src="https://via.placeholder.com/400x250/4ECDC4/FFFFFF?text=Hotel+Lima" alt="Oferta Hotel Lima">
                        <div class="tour-badge tour-badge-new">-25%</div>
                    </div>
                    <div class="tour-content">
                        <h3 class="tour-title">Hoteles Premium Lima</h3>
                        <div class="tour-meta">
                            <span class="tour-duration"><i class="fas fa-fire"></i> Promoción</span>
                            <span class="tour-difficulty difficulty-facil">Hotel 4⭐</span>
                        </div>
                        <p class="tour-description">Lujo en el corazón de Lima. Acceso a spa premium, piscina con vista al océano, restaurantes Michelin y servicio 24h.</p>
                        <div class="tour-features">
                            <span class="feature-tag">Spa incluido</span>
                            <span class="feature-tag">Desayuno 5⭐</span>
                            <span class="feature-tag">Upgrade gratis</span>
                        </div>
                        <div class="tour-footer">
                            <div class="tour-price">
                                <span class="price-label">Desde</span>
                                <span class="price-value">S/ 435</span>
                            </div>
                            <button class="btn-tour-reserve" onclick="showNotification('Solicitud de reserva enviada', 'success')">Aprovechar</button>
                        </div>
                    </div>
                </div>

                <!-- Offer 3 -->
                <div class="tour-card">
                    <div class="tour-image">
                        <img src="https://via.placeholder.com/400x250/95E1D3/FFFFFF?text=Vuelos" alt="Oferta Vuelos">
                        <div class="tour-badge tour-badge-top">-40%</div>
                    </div>
                    <div class="tour-content">
                        <h3 class="tour-title">Vuelos Nacionales</h3>
                        <div class="tour-meta">
                            <span class="tour-duration"><i class="fas fa-fire"></i> Mega Oferta</span>
                            <span class="tour-difficulty difficulty-facil">Directo</span>
                        </div>
                        <p class="tour-description">Vuela a cualquier destino nacional con descuentos especiales. Todas las rutas principales a precios increíbles.</p>
                        <div class="tour-features">
                            <span class="feature-tag">Todos destinos</span>
                            <span class="feature-tag">Equipaje doble</span>
                            <span class="feature-tag">Cambio gratis</span>
                        </div>
                        <div class="tour-footer">
                            <div class="tour-price">
                                <span class="price-label">Desde</span>
                                <span class="price-value">S/ 168</span>
                            </div>
                            <button class="btn-tour-reserve" onclick="showNotification('Solicitud de reserva enviada', 'success')">Aprovechar</button>
                        </div>
                    </div>
                </div>

                <!-- Offer 4 -->
                <div class="tour-card">
                    <div class="tour-image">
                        <img src="https://via.placeholder.com/400x250/F38181/FFFFFF?text=Valle+Sagrado" alt="Oferta Paquete Valle">
                        <div class="tour-badge tour-badge-popular">-30%</div>
                    </div>
                    <div class="tour-content">
                        <h3 class="tour-title">Valle Sagrado Express</h3>
                        <div class="tour-meta">
                            <span class="tour-duration"><i class="fas fa-calendar-days"></i> 2 Días</span>
                            <span class="tour-difficulty difficulty-facil">Paquete</span>
                        </div>
                        <p class="tour-description">Recorrido completo: Ollantaytambo, Pisac, Chinchero. Incluye hotel, transporte, guía y comidas típicas.</p>
                        <div class="tour-features">
                            <span class="feature-tag">Grupos pequeños</span>
                            <span class="feature-tag">Mercados locales</span>
                            <span class="feature-tag">Fotos profesionales</span>
                        </div>
                        <div class="tour-footer">
                            <div class="tour-price">
                                <span class="price-label">Desde</span>
                                <span class="price-value">S/ 434</span>
                            </div>
                            <button class="btn-tour-reserve" onclick="showNotification('Solicitud de reserva enviada', 'success')">Aprovechar</button>
                        </div>
                    </div>
                </div>

                <!-- Offer 5 -->
                <div class="tour-card">
                    <div class="tour-image">
                        <img src="https://via.placeholder.com/400x250/AA96DA/FFFFFF?text=Selva" alt="Oferta Selva">
                        <div class="tour-badge tour-badge-new">-28%</div>
                    </div>
                    <div class="tour-content">
                        <h3 class="tour-title">Aventura en la Selva</h3>
                        <div class="tour-meta">
                            <span class="tour-duration"><i class="fas fa-calendar-days"></i> 3 Días</span>
                            <span class="tour-difficulty difficulty-dificil">All-Inclusive</span>
                        </div>
                        <p class="tour-description">Lodge ecológico en la Amazonía. Tours diarios, guía naturalista, todas las comidas y avistamiento de fauna.</p>
                        <div class="tour-features">
                            <span class="feature-tag">Comunidades nativas</span>
                            <span class="feature-tag">Naturalista experto</span>
                            <span class="feature-tag">Todas meals</span>
                        </div>
                        <div class="tour-footer">
                            <div class="tour-price">
                                <span class="price-label">Desde</span>
                                <span class="price-value">S/ 706</span>
                            </div>
                            <button class="btn-tour-reserve" onclick="showNotification('Solicitud de reserva enviada', 'success')">Aprovechar</button>
                        </div>
                    </div>
                </div>

                <!-- Offer 6 -->
                <div class="tour-card">
                    <div class="tour-image">
                        <img src="https://via.placeholder.com/400x250/FCBAD3/FFFFFF?text=Titicaca" alt="Oferta Titicaca">
                        <div class="tour-badge tour-badge-top">-22%</div>
                    </div>
                    <div class="tour-content">
                        <h3 class="tour-title">Lago Titicaca Completo</h3>
                        <div class="tour-meta">
                            <span class="tour-duration"><i class="fas fa-calendar-days"></i> 3 Días</span>
                            <span class="tour-difficulty difficulty-moderado">Aventura</span>
                        </div>
                        <p class="tour-description">Islas flotantes, Isla de Taquile, pueblos ancestrales. Hotel frente al lago con vistas épicas del atardecer.</p>
                        <div class="tour-features">
                            <span class="feature-tag">Bote turístico</span>
                            <span class="feature-tag">Casa local Taquile</span>
                            <span class="feature-tag">Artesanías</span>
                        </div>
                        <div class="tour-footer">
                            <div class="tour-price">
                                <span class="price-label">Desde</span>
                                <span class="price-value">S/ 663</span>
                            </div>
                            <button class="btn-tour-reserve" onclick="showNotification('Solicitud de reserva enviada', 'success')">Aprovechar</button>
                        </div>
                    </div>
                </div>

            </div>
        </section>

        <!-- Why Choose Ofertas Section -->
        <section class="why-choose-section mt-20">
            <h2 class="section-title mb-12">¿Por qué nos eligen en Ofertas?</h2>
            <div class="why-choose-grid">
                <div class="why-choose-card">
                    <i class="fas fa-percentage why-choose-icon"></i>
                    <h3 class="why-choose-title">Descuentos Reales</h3>
                    <p class="why-choose-text">Sin trampas, sin aumentar precios antes. Descuentos genuinos verificados y auditorados.</p>
                </div>
                <div class="why-choose-card">
                    <i class="fas fa-bell why-choose-icon"></i>
                    <h3 class="why-choose-title">Alertas Exclusivas</h3>
                    <p class="why-choose-text">Suscríbete para recibir notificaciones de ofertas flash y promociones antes que nadie.</p>
                </div>
                <div class="why-choose-card">
                    <i class="fas fa-clock why-choose-icon"></i>
                    <h3 class="why-choose-title">Tiempo Limitado</h3>
                    <p class="why-choose-text">Ofertas cambian semanalmente para garantizar que siempre hay algo nuevo y fresco.</p>
                </div>
                <div class="why-choose-card">
                    <i class="fas fa-lock why-choose-icon"></i>
                    <h3 class="why-choose-title">Precio Garantizado</h3>
                    <p class="why-choose-text">Si encuentras un precio mejor, nosotros lo igualamos + descuento adicional del 5%.</p>
                </div>
                <div class="why-choose-card">
                    <i class="fas fa-check why-choose-icon"></i>
                    <h3 class="why-choose-title">Sin Condiciones Ocultas</h3>
                    <p class="why-choose-text">Todas las condiciones están claramente especificadas. Transparencia total en cada oferta.</p>
                </div>
                <div class="why-choose-card">
                    <i class="fas fa-gift why-choose-icon"></i>
                    <h3 class="why-choose-title">Bonificaciones Extra</h3>
                    <p class="why-choose-text">Obtén puntos de recompensa en cada compra para futuras promociones aún mejores.</p>
                </div>
            </div>
        </section>

        <!-- CTA Section -->
        <section class="cta-section mt-20 bg-gradient-to-r from-red-600 to-orange-500 rounded-2xl px-8 py-12 text-white">
            <div class="max-w-2xl mx-auto text-center">
                <h2 class="text-3xl font-bold mb-4">¡No dejes pasar estas Ofertas!</h2>
                <p class="text-lg mb-8 text-red-100">Las mejores promociones del año están aquí - descuentos limitados a tiempo</p>
                <button class="btn-cta-primary" onclick="showNotification('Te contactaremos pronto', 'success')">Aprovechar Ahora</button>
            </div>
        </section>

        <!-- Coming Soon Section -->
        <div class="coming-soon-container" style="margin-top: 60px;">
            <i class="fas fa-tag coming-soon-icon"></i>
            <h2 class="coming-soon-title">Más Ofertas</h2>
            <p class="coming-soon-text">Agregamos nuevas ofertas especiales cada semana. Suscríbete a nuestro newsletter para no perderte ninguna promoción.</p>
        </div>
    </main>
</AppLayout>


