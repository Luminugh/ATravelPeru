{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/forgot-password/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/register/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/support/?$",
			"dest": "_render"
		},
		{
			"src": "^/ayuda/?$",
			"dest": "_render"
		},
		{
			"src": "^/hoteles/?$",
			"dest": "_render"
		},
		{
			"src": "^/ofertas/?$",
			"dest": "_render"
		},
		{
			"src": "^/packages/?$",
			"dest": "_render"
		},
		{
			"src": "^/paquetes/?$",
			"dest": "_render"
		},
		{
			"src": "^/tours-at/?$",
			"dest": "_render"
		},
		{
			"src": "^/vuelos/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		}
	]
}