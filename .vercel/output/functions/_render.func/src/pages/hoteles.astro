---
import AppLayout from "../layouts/AppLayout.astro";

const title = "Hoteles - ATRAVEL";
---

<AppLayout title={title}>
<!-- Hero Section Hoteles -->
    <section class="hero-section">
        <div class="hero-background">
            <video autoplay muted loop class="hero-video">
                <source src="/assets/videos/Video1.mp4" type="video/mp4">
                Tu navegador no soporta videos.
            </video>
        </div>
        <div class="hero-overlay"></div>
        <div class="hero-content">
            <div class="hero-badge">Tu hogar en el camino</div>
            <h2 class="hero-title">Hoteles de Lujo para tu Estadía</h2>
            <p class="hero-subtitle">Descubre alojamientos premium en los destinos más hermosos del Perú con servicios de clase mundial</p>
            
            <div class="hero-features">
                <div class="hero-feature-item">
                    <i class="fas fa-star feature-icon"></i>
                    <span class="feature-text">4-5 Estrellas</span>
                </div>
                <div class="hero-feature-item">
                    <i class="fas fa-map-pin feature-icon"></i>
                    <span class="feature-text">100+ Destinos</span>
                </div>
                <div class="hero-feature-item">
                    <i class="fas fa-certificate feature-icon"></i>
                    <span class="feature-text">Garantía Calidad</span>
                </div>
            </div>

            <div class="hero-actions">
                <button class="btn-hero-primary" onclick="document.querySelector('.hoteles-search-form').scrollIntoView({behavior: 'smooth'})">Buscar Hoteles</button>
                <button class="btn-hero-secondary">Ver Mejores Ofertas</button>
            </div>
        </div>
    </section>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        
        <!-- Search Form Section -->
        <section class="hoteles-search-form mb-12">
            <h2 class="text-2xl font-bold mb-8 text-gray-900">Encuentra tu Alojamiento Perfecto</h2>
            <div class="filters-container">
                <div class="filter-group">
                    <label class="filter-label">Destino</label>
                    <select class="filter-select">
                        <option>Todos los destinos</option>
                        <option>Lima</option>
                        <option>Cusco</option>
                        <option>Arequipa</option>
                        <option>Iquitos</option>
                        <option>Puno</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label class="filter-label">Check-in</label>
                    <input type="date" class="filter-input">
                </div>
                <div class="filter-group">
                    <label class="filter-label">Check-out</label>
                    <input type="date" class="filter-input">
                </div>
                <div class="filter-group">
                    <label class="filter-label">Huéspedes</label>
                    <select class="filter-select">
                        <option>1 Huésped</option>
                        <option>2 Huéspedes</option>
                        <option>3 Huéspedes</option>
                        <option>4+ Huéspedes</option>
                    </select>
                </div>
                <button class="btn-filter-search">Buscar</button>
            </div>
        </section>

        <!-- Hotels Grid Section -->
        <section class="tours-section">
            <h2 class="section-title mb-12">Hoteles Destacados</h2>
            <div class="tours-grid">
                
                <!-- Hotel 1 -->
                <div class="tour-card">
                    <div class="tour-image">
                        <img src="https://via.placeholder.com/400x250/FF6B6B/FFFFFF?text=Hotel+Cusco+Palace" alt="Hotel Cusco Palace">
                        <div class="tour-badge tour-badge-popular">Popular</div>
                    </div>
                    <div class="tour-content">
                        <h3 class="tour-title">Cusco Palace 5⭐</h3>
                        <div class="tour-meta">
                            <span class="tour-duration"><i class="fas fa-map-pin"></i> Centro Histórico</span>
                            <span class="tour-difficulty difficulty-moderado">Premium</span>
                        </div>
                        <p class="tour-description">Lujo absoluto en el corazón de Cusco. Vistas a la plaza de armas, restaurante gourmet y spa de clase mundial.</p>
                        <div class="tour-features">
                            <span class="feature-tag">Wi-Fi Premium</span>
                            <span class="feature-tag">Desayuno 5 estrellas</span>
                            <span class="feature-tag">Spa & Sauna</span>
                        </div>
                        <div class="tour-footer">
                            <div class="tour-price">
                                <span class="price-label">Desde</span>
                                <span class="price-value">S/ 650</span>
                            </div>
                            <button class="btn-tour-reserve" onclick="openLoginModal()">Reservar</button>
                        </div>
                    </div>
                </div>

                <!-- Hotel 2 -->
                <div class="tour-card">
                    <div class="tour-image">
                        <img src="https://via.placeholder.com/400x250/4ECDC4/FFFFFF?text=Hotel+Lima+Elegancia" alt="Hotel Lima Elegancia">
                        <div class="tour-badge tour-badge-new">Nuevo</div>
                    </div>
                    <div class="tour-content">
                        <h3 class="tour-title">Lima Elegancia 5⭐</h3>
                        <div class="tour-meta">
                            <span class="tour-duration"><i class="fas fa-map-pin"></i> Miraflores</span>
                            <span class="tour-difficulty difficulty-facil">Lujo</span>
                        </div>
                        <p class="tour-description">Hotel boutique con vistas al océano Pacífico. Arquitectura moderna y gastronomía contemporánea.</p>
                        <div class="tour-features">
                            <span class="feature-tag">Terraza panorámica</span>
                            <span class="feature-tag">Chef gourmet</span>
                            <span class="feature-tag">Room service 24h</span>
                        </div>
                        <div class="tour-footer">
                            <div class="tour-price">
                                <span class="price-label">Desde</span>
                                <span class="price-value">S/ 580</span>
                            </div>
                            <button class="btn-tour-reserve" onclick="openLoginModal()">Reservar</button>
                        </div>
                    </div>
                </div>

                <!-- Hotel 3 -->
                <div class="tour-card">
                    <div class="tour-image">
                        <img src="https://via.placeholder.com/400x250/95E1D3/FFFFFF?text=Lodge+Iquitos" alt="Lodge Iquitos">
                    </div>
                    <div class="tour-content">
                        <h3 class="tour-title">Amazon Lodge Iquitos 4⭐</h3>
                        <div class="tour-meta">
                            <span class="tour-duration"><i class="fas fa-map-pin"></i> Ribera Río Amazonas</span>
                            <span class="tour-difficulty difficulty-moderado">Eco-Lodge</span>
                        </div>
                        <p class="tour-description">Inmersión en la selva con todas las comodidades. Naturaleza virgen, actividades de aventura y comida amazónica.</p>
                        <div class="tour-features">
                            <span class="feature-tag">Tours selva incluida</span>
                            <span class="feature-tag">Guía naturalista</span>
                            <span class="feature-tag">Comidas típicas</span>
                        </div>
                        <div class="tour-footer">
                            <div class="tour-price">
                                <span class="price-label">Desde</span>
                                <span class="price-value">S/ 420</span>
                            </div>
                            <button class="btn-tour-reserve" onclick="openLoginModal()">Reservar</button>
                        </div>
                    </div>
                </div>

                <!-- Hotel 4 -->
                <div class="tour-card">
                    <div class="tour-image">
                        <img src="https://via.placeholder.com/400x250/F38181/FFFFFF?text=Hotel+Arequipa+Patrimonio" alt="Hotel Arequipa Patrimonio">
                        <div class="tour-badge tour-badge-top">Top Rating</div>
                    </div>
                    <div class="tour-content">
                        <h3 class="tour-title">Arequipa Patrimonio 4⭐</h3>
                        <div class="tour-meta">
                            <span class="tour-duration"><i class="fas fa-map-pin"></i> Centro Histórico</span>
                            <span class="tour-difficulty difficulty-facil">Boutique</span>
                        </div>
                        <p class="tour-description">Casona histórica restaurada con estilo colonial. Experiencia auténtica en la segunda ciudad del Perú.</p>
                        <div class="tour-features">
                            <span class="feature-tag">Patrimonio UNESCO</span>
                            <span class="feature-tag">Arquitectura colonial</span>
                            <span class="feature-tag">Patio colonial</span>
                        </div>
                        <div class="tour-footer">
                            <div class="tour-price">
                                <span class="price-label">Desde</span>
                                <span class="price-value">S/ 380</span>
                            </div>
                            <button class="btn-tour-reserve" onclick="openLoginModal()">Reservar</button>
                        </div>
                    </div>
                </div>

                <!-- Hotel 5 -->
                <div class="tour-card">
                    <div class="tour-image">
                        <img src="https://via.placeholder.com/400x250/AA96DA/FFFFFF?text=Hotel+Puno+Titicaca" alt="Hotel Puno Titicaca">
                    </div>
                    <div class="tour-content">
                        <h3 class="tour-title">Puno Titicaca 4⭐</h3>
                        <div class="tour-meta">
                            <span class="tour-duration"><i class="fas fa-map-pin"></i> Frente al Lago</span>
                            <span class="tour-difficulty difficulty-facil">Frente Agua</span>
                        </div>
                        <p class="tour-description">Vistas espectaculares al lago Titicaca, tierra del Inti Raymi. Punto de partida a las islas flotantes.</p>
                        <div class="tour-features">
                            <span class="feature-tag">Balcón lago</span>
                            <span class="feature-tag">Tours islas</span>
                            <span class="feature-tag">Restaurante típico</span>
                        </div>
                        <div class="tour-footer">
                            <div class="tour-price">
                                <span class="price-label">Desde</span>
                                <span class="price-value">S/ 340</span>
                            </div>
                            <button class="btn-tour-reserve" onclick="openLoginModal()">Reservar</button>
                        </div>
                    </div>
                </div>

                <!-- Hotel 6 -->
                <div class="tour-card">
                    <div class="tour-image">
                        <img src="https://via.placeholder.com/400x250/FCBAD3/FFFFFF?text=Hotel+Aventura+Aguas+Calientes" alt="Hotel Aguas Calientes">
                    </div>
                    <div class="tour-content">
                        <h3 class="tour-title">Aguas Calientes Resort 4⭐</h3>
                        <div class="tour-meta">
                            <span class="tour-duration"><i class="fas fa-map-pin"></i> Pueblo Machu Picchu</span>
                            <span class="tour-difficulty difficulty-moderado">Resort</span>
                        </div>
                        <p class="tour-description">Base perfecta para explorar Machu Picchu. Aguas termales naturales, gastronomía andina y acceso directo ferrocarril.</p>
                        <div class="tour-features">
                            <span class="feature-tag">Aguas termales</span>
                            <span class="feature-tag">Estación ferrocarril</span>
                            <span class="feature-tag">Guías incluidos</span>
                        </div>
                        <div class="tour-footer">
                            <div class="tour-price">
                                <span class="price-label">Desde</span>
                                <span class="price-value">S/ 490</span>
                            </div>
                            <button class="btn-tour-reserve" onclick="openLoginModal()">Reservar</button>
                        </div>
                    </div>
                </div>

            </div>
        </section>

        <!-- Why Choose Hoteles Section -->
        <section class="why-choose-section mt-20">
            <h2 class="section-title mb-12">¿Por qué elegir nuestros Hoteles?</h2>
            <div class="why-choose-grid">
                <div class="why-choose-card">
                    <i class="fas fa-crown why-choose-icon"></i>
                    <h3 class="why-choose-title">Calidad Garantizada</h3>
                    <p class="why-choose-text">Solo seleccionamos hoteles con certificación y excelentes críticas de huéspedes.</p>
                </div>
                <div class="why-choose-card">
                    <i class="fas fa-tag why-choose-icon"></i>
                    <h3 class="why-choose-title">Mejores Tarifas</h3>
                    <p class="why-choose-text">Negociamos directamente con los hoteles para ofrecerte las mejores estratas del mercado.</p>
                </div>
                <div class="why-choose-card">
                    <i class="fas fa-laptop why-choose-icon"></i>
                    <h3 class="why-choose-title">Booking Fácil</h3>
                    <p class="why-choose-text">Reserva en línea de forma segura con confirmación instantánea en tu correo electrónico.</p>
                </div>
                <div class="why-choose-card">
                    <i class="fas fa-sync-alt why-choose-icon"></i>
                    <h3 class="why-choose-title">Cambios Gratis</h3>
                    <p class="why-choose-text">Modifica o cancela tu reserva sin cargos hasta 72 horas antes de tu llegada.</p>
                </div>
                <div class="why-choose-card">
                    <i class="fas fa-person-booth why-choose-icon"></i>
                    <h3 class="why-choose-title">Atención Personalizada</h3>
                    <p class="why-choose-text">Nuestros asesores conocen cada hotel y te ayudan a elegir el que más te convenga.</p>
                </div>
                <div class="why-choose-card">
                    <i class="fas fa-question-circle why-choose-icon"></i>
                    <h3 class="why-choose-title">Soporte 24/7</h3>
                    <p class="why-choose-text">¿Problemas en el hotel? Nuestro equipo está disponible para resolver cualquier inconveniente.</p>
                </div>
            </div>
        </section>

        <!-- CTA Section -->
        <section class="cta-section mt-20 bg-gradient-to-r from-pink-600 to-rose-500 rounded-2xl px-8 py-12 text-white">
            <div class="max-w-2xl mx-auto text-center">
                <h2 class="text-3xl font-bold mb-4">Relájate en Destinos Paradisíacos</h2>
                <p class="text-lg mb-8 text-pink-100">Encuentra el hotel perfecto para tu próximo viaje</p>
                <button class="btn-cta-primary" onclick="openRegisterModal()">Reservar Hotel Ahora</button>
            </div>
        </section>
    </main>
</AppLayout>

